digraph agents_level {
    graph [rankdir=LR fontname="Helvetica" fontsize=12
           label="amplifier/agents — Level Synthesis\n(single agent definition, leaf directory)"
           labelloc=t compound=true]
    node [fontname="Helvetica" fontsize=11 style=filled]
    edge [fontname="Helvetica" fontsize=10]

    // ── This-level node ─────────────────────────────────────────────────────
    amplifier_expert_md [
        label="amplifier-expert.md\n«agent definition»\nname: amplifier-expert\nmodel_role: general"
        shape=note fillcolor="#ddeeff"
    ]

    // ── Internal structure: operating modes ─────────────────────────────────
    subgraph cluster_modes {
        label="Operating Modes"
        style=filled fillcolor="#eef0ff"
        mode_research [label="RESEARCH\n«any question»\nwhat/how/what-can" shape=box fillcolor="#eef0ff"]
        mode_guide    [label="GUIDE\n«planning»\nhow-should/what-pattern" shape=box fillcolor="#eef0ff"]
        mode_validate [label="VALIDATE\n«review»\nis-this-right/align" shape=box fillcolor="#eef0ff"]
    }

    // ── Internal structure: knowledge tiers ─────────────────────────────────
    subgraph cluster_tiers {
        label="Knowledge Tiers"
        style=filled fillcolor="#e8f5e9"
        tier0 [label="Tier 0\namplifier-core\n(kernel, ~2600 lines)" shape=box fillcolor="#e8f5e9"]
        tier1 [label="Tier 1\namplifier\n(entry point docs)" shape=box fillcolor="#e8f5e9"]
        tier2 [label="Tier 2\namplifier-foundation\n(bundle library)" shape=box fillcolor="#e8f5e9"]
        tier3 [label="Tier 3\nCore Philosophy\n(@foundation:context/)" shape=box fillcolor="#e8f5e9"]
        tier4 [label="Tier 4\nRecipes\n(multi-step workflows)" shape=box fillcolor="#e8f5e9"]
    }

    // ── External ecosystem bundles ───────────────────────────────────────────
    subgraph cluster_ext_bundles {
        label="External Bundle References (@-mentions)"
        style=filled fillcolor="#eeeeee"
        ext_core       [label="@core:\namplifier-core" shape=component fillcolor="#eeeeee"]
        ext_amplifier  [label="@amplifier:\namplifier" shape=component fillcolor="#eeeeee"]
        ext_foundation [label="@foundation:\namplifier-foundation" shape=component fillcolor="#eeeeee"]
        ext_recipes    [label="@recipes:\nrecipes" shape=component fillcolor="#eeeeee"]
        ext_base       [label="@foundation:context/shared/\ncommon-agent-base.md\n«shared base include»" shape=note fillcolor="#eeeeee"]
    }

    // ── Peer expert agents (collaboration / delegation) ──────────────────────
    subgraph cluster_peers {
        label="Peer Expert Agents (delegation targets)"
        style=filled fillcolor="#fff8e1"
        peer_core_expert       [label="core:core-expert\n«kernel contracts»" shape=box fillcolor="#fff8e1"]
        peer_foundation_expert [label="foundation:foundation-expert\n«bundle patterns»" shape=box fillcolor="#fff8e1"]
        peer_recipe_author     [label="recipes:recipe-author\n«multi-step workflows»" shape=box fillcolor="#fff8e1"]
    }

    // ── Edges: file → modes ──────────────────────────────────────────────────
    amplifier_expert_md -> mode_research [label="activates"]
    amplifier_expert_md -> mode_guide    [label="activates"]
    amplifier_expert_md -> mode_validate [label="activates"]

    // ── Edges: file → tiers ──────────────────────────────────────────────────
    amplifier_expert_md -> tier0 [label="knowledge base"]
    amplifier_expert_md -> tier1
    amplifier_expert_md -> tier2
    amplifier_expert_md -> tier3
    amplifier_expert_md -> tier4

    // ── Edges: tiers → external bundles ─────────────────────────────────────
    tier0 -> ext_core       [label="@-mentions"]
    tier1 -> ext_amplifier  [label="@-mentions"]
    tier2 -> ext_foundation [label="@-mentions"]
    tier3 -> ext_foundation [label="@context/"]
    tier4 -> ext_recipes    [label="@-mentions"]

    // ── Edges: common base include ───────────────────────────────────────────
    amplifier_expert_md -> ext_base [label="includes" style=dashed]

    // ── Edges: delegation to peers ───────────────────────────────────────────
    amplifier_expert_md -> peer_core_expert       [label="routes\nkernel Q's" style=dashed color="#888888"]
    amplifier_expert_md -> peer_foundation_expert [label="routes\nbundle Q's" style=dashed color="#888888"]
    amplifier_expert_md -> peer_recipe_author     [label="routes\nworkflow Q's" style=dashed color="#888888"]

    // ── Legend ───────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend" style=filled fillcolor="#ffffff"
        leg_thisfile [label="This-level file (note)" shape=note fillcolor="#ddeeff"]
        leg_ext      [label="External bundle (component)" shape=component fillcolor="#eeeeee"]
        leg_peer     [label="Peer/collaborator agent (box)" shape=box fillcolor="#fff8e1"]
        leg_solid    [label="direct reference" shape=plaintext fillcolor="#ffffff"]
        leg_dashed   [label="delegation / include" shape=plaintext fillcolor="#ffffff"]
        leg_solid  -> leg_dashed [style=dashed label="= loose coupling"]
    }
}
