digraph assets_branding_favicons {
    graph [label="assets/branding/favicons — Level Synthesis\n(leaf directory: static favicon assets)", labelloc=t, fontsize=14, fontname="Helvetica", bgcolor="white"];
    node [fontname="Helvetica", fontsize=11];
    edge [fontname="Helvetica", fontsize=10];

    subgraph cluster_favicons {
        label="favicons/  (leaf directory — no subdirectories)";
        style=filled;
        fillcolor="#eeeeee";
        fontsize=12;
        fontname="Helvetica Bold";

        apple_touch [label="apple-touch-icon.png\n(38,612 bytes)", shape=note, style=filled, fillcolor="#ddeeff"];
        favicon32   [label="favicon-32.png\n(2,772 bytes)", shape=note, style=filled, fillcolor="#ddeeff"];
        favicon_ico [label="favicon.ico\n(969 bytes)", shape=note, style=filled, fillcolor="#ddeeff"];
    }

    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#ffffff";
        fontsize=10;

        legend_file  [label="note shape = static binary file", shape=note, style=filled, fillcolor="#ddeeff", fontsize=9];
        legend_child [label="grey fill = child cluster", shape=box, style=filled, fillcolor="#eeeeee", fontsize=9];
        legend_file -> legend_child [style=invis];
    }
}
