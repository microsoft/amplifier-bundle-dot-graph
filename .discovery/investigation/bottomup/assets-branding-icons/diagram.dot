digraph assets_branding_icons {
    label="assets/branding/icons — Amplifier Icon Asset Set"
    labelloc=t
    rankdir=TB
    node [fontname="Helvetica" fontsize=11]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    // ── macOS platform container ──────────────────────────────────────────
    subgraph cluster_macos {
        label="macOS Platform"
        style=filled fillcolor="#E3F2FD"
        node [shape=cylinder style=filled fillcolor="#BBDEFB"]
        icns [label="Amplifier.icns\n(1.75 MB)\nmulti-res bundle"]
    }

    // ── Windows platform container ────────────────────────────────────────
    subgraph cluster_windows {
        label="Windows Platform"
        style=filled fillcolor="#FFF3E0"
        node [shape=cylinder style=filled fillcolor="#FFE0B2"]
        ico [label="amplifier-windows.ico\n(969 B)"]
    }

    // ── Menu bar specialty set ────────────────────────────────────────────
    subgraph cluster_menubar {
        label="Menu Bar Icons (macOS menu bar)"
        style=filled fillcolor="#E8F5E9"
        node [shape=note style=filled fillcolor="#C8E6C9" fontsize=10]
        menubar_1x [label="MenuBarIcon.png\n(522 B)  1x"]
        menubar_2x [label="MenuBarIcon@2x.png\n(1.3 KB)  2x retina"]
    }

    // ── PNG source series ─────────────────────────────────────────────────
    subgraph cluster_pngs {
        label="Application Icon PNG Series (cross-platform)"
        style=filled fillcolor="#F5F5F5"
        node [shape=note style=filled fillcolor="#EEEEEE" fontsize=10]
        png_16   [label="amplifier-icon-16.png\n16 px · 947 B"]
        png_22   [label="amplifier-icon-22.png\n22 px · 1.5 KB  (Linux tray)"]
        png_32   [label="amplifier-icon-32.png\n32 px · 2.7 KB"]
        png_44   [label="amplifier-icon-44.png\n44 px · 4.5 KB  (Win taskbar)"]
        png_48   [label="amplifier-icon-48.png\n48 px · 5.1 KB  (Linux/Android)"]
        png_64   [label="amplifier-icon-64.png\n64 px · 8.0 KB"]
        png_128  [label="amplifier-icon-128.png\n128 px · 22.6 KB"]
        png_256  [label="amplifier-icon-256.png\n256 px · 66 KB"]
        png_512  [label="amplifier-icon-512.png\n512 px · 228 KB"]
        png_1024 [label="amplifier-icon-1024.png\n1024 px · 842 KB  ★ master"]
    }

    // ── Retina pair relationship ──────────────────────────────────────────
    menubar_1x -> menubar_2x [label="@2x retina pair" style=dashed dir=none color="#888888"]

    // ── PNG → macOS bundle (representative subset) ────────────────────────
    png_16   -> icns [label="bundled" style=dashed color="#4a90d9"]
    png_32   -> icns [style=dashed color="#4a90d9"]
    png_128  -> icns [style=dashed color="#4a90d9"]
    png_256  -> icns [style=dashed color="#4a90d9"]
    png_512  -> icns [style=dashed color="#4a90d9"]
    png_1024 -> icns [style=dashed color="#4a90d9"]

    // ── PNG → Windows ICO bundle ──────────────────────────────────────────
    png_16  -> ico [label="bundled" style=dashed color="#e67e22"]
    png_32  -> ico [style=dashed color="#e67e22"]
    png_48  -> ico [style=dashed color="#e67e22"]
    png_256 -> ico [style=dashed color="#e67e22"]

    // ── Legend ────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#FAFAFA"
        node [width=2.2 fontsize=10]
        L_bundle [label="Platform Bundle\n(.icns / .ico)"      shape=cylinder style=filled fillcolor="#BBDEFB"]
        L_png    [label="PNG Source Asset\n(individual size)"  shape=note    style=filled fillcolor="#EEEEEE"]
        L_menu   [label="Menu Bar Asset\n(specialty icon)"     shape=note    style=filled fillcolor="#C8E6C9"]
        L_bundle -> L_png  [style=invis]
        L_png    -> L_menu [style=invis]
    }
}
