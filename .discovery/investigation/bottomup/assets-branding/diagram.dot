digraph assets_branding {
    graph [
        label="assets/branding — Amplifier Branding Asset Distribution"
        labelloc=t
        fontsize=14
        rankdir=TB
        bgcolor=white
        pad=0.5
        compound=true
    ]
    node [fontsize=10 margin="0.15,0.08"]
    edge [fontsize=9]

    // This-level node (blue fill)
    readme [
        label="README.md\n(master docs + usage guide\nHTML / PWA / generation)"
        shape=note
        style=filled
        fillcolor="#ddeeff"
    ]

    // External origin
    github_src [
        label="GitHub Avatar\nmicrosoft-amplifier\n(460x460 source)"
        shape=ellipse
        style=filled
        fillcolor="#ffeecc"
    ]

    subgraph cluster_icons {
        label="icons/  (14 files — native app icons)"
        style=filled
        fillcolor="#eeeeee"
        fontsize=11

        master [
            label="amplifier-icon-1024.png\n★ Master Source (1024x1024)"
            shape=box
            style="filled,bold"
            fillcolor="#ffdddd"
            penwidth=2
        ]
        icon_512  [label="amplifier-icon-512.png\n(512x512)"                              shape=note style=filled fillcolor="#eeeeee"]
        icon_32   [label="amplifier-icon-32.png\n(32x32)"                                 shape=note style=filled fillcolor="#eeeeee"]
        icon_other [label="amplifier-icon-{16,22,44,48,64,128,256}.png\n(7 other PNG sizes)" shape=note style=filled fillcolor="#eeeeee"]
        plat_bundles [label="Amplifier.icns + amplifier-windows.ico\n(macOS + Windows multi-size bundles)" shape=component style=filled fillcolor="#eeeeee"]
        menubar   [label="MenuBarIcon.png + MenuBarIcon@2x.png\n(black+alpha template — macOS tray)" shape=note style=filled fillcolor="#eeeeee"]

        master -> icon_512    [style=dashed]
        master -> icon_32     [style=dashed]
        master -> icon_other  [style=dashed label="resize"]
        master -> plat_bundles [style=dashed label="bundle"]
        master -> menubar     [style=dashed label="template"]
    }

    subgraph cluster_favicons {
        label="favicons/  (3 files — web browser)"
        style=filled
        fillcolor="#eeeeee"
        fontsize=11

        fav_ico   [label="favicon.ico\n(16+32+48 multi-resolution)" shape=note style=filled fillcolor="#eeeeee"]
        fav_32    [label="favicon-32.png\n(32x32)"                  shape=note style=filled fillcolor="#eeeeee"]
        fav_touch [label="apple-touch-icon.png\n(180x180 iOS)"      shape=note style=filled fillcolor="#eeeeee"]
    }

    subgraph cluster_pwa {
        label="pwa/  (2 files — Progressive Web App)"
        style=filled
        fillcolor="#eeeeee"
        fontsize=11

        pwa_192 [label="pwa-192.png\n(192x192 manifest icon)" shape=note style=filled fillcolor="#eeeeee"]
        pwa_512 [label="pwa-512.png\n(512x512 splash screen)" shape=note style=filled fillcolor="#eeeeee"]
    }

    // External origin to master
    github_src -> master [label="AI upscale\n460 to 1024px" color="#888888"]

    // Cross-child IDENTITY edges (primary finding — same bytes in different dirs)
    icon_32  -> fav_32  [label="IDENTICAL FILE\n(2772 bytes each)"   color="#cc4400" style=bold penwidth=2]
    icon_512 -> pwa_512 [label="IDENTICAL FILE\n(233792 bytes each)" color="#cc4400" style=bold penwidth=2]

    // Cross-child derivative edges (master in icons/ drives files in favicons/ and pwa/)
    master -> fav_ico   [label="multi-res\nderivative" style=dashed color="#666666"]
    master -> fav_touch [label="resize to 180px"       style=dashed color="#666666"]
    master -> pwa_192   [label="resize to 192px"       style=dashed color="#666666"]

    // README at this level documents all three child directories
    readme -> master [label="documents\nall assets" style=dotted color="#888888"]

    // Legend
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#ffffff"
        fontsize=10

        leg_readme  [label="This-level file (blue)"             shape=note    style=filled        fillcolor="#ddeeff"  fontsize=9]
        leg_master  [label="Master source (pink, bold border)"  shape=box     style="filled,bold" fillcolor="#ffdddd"  fontsize=9 penwidth=2]
        leg_asset   [label="Derived asset (gray)"               shape=note    style=filled        fillcolor="#eeeeee"  fontsize=9]
        leg_extern  [label="External origin (orange)"           shape=ellipse style=filled        fillcolor="#ffeecc"  fontsize=9]
        leg_ident   [label="IDENTICAL cross-child copy\n(orange bold edge)"  shape=plaintext fontsize=9]
        leg_derive  [label="Resize/derivative (gray dashed edge)"            shape=plaintext fontsize=9]
    }
}
