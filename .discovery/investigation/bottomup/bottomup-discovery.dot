digraph amplifier_subsystem {
  graph [
    label="amplifier/ — Subsystem Synthesis\nCross-Module Boundaries and Data Flows"
    labelloc=t fontname="Helvetica" fontsize=14
    rankdir=TB compound=true nodesep=0.6 ranksep=0.9 bgcolor="white"
  ]
  node [fontname="Helvetica" fontsize=10 style=filled]
  edge [fontname="Helvetica" fontsize=9]

  // Root Bundle
  bundle_md [label="bundle.md\n(entry point)" shape=component fillcolor="#ddeeff"]

  // Module: agents/
  subgraph cluster_agents {
    label="agents/" style=filled fillcolor="#eeeeee" color="#999999"
    agent_expert [label="amplifier-expert.md\n(ecosystem router)" shape=box style="rounded,filled" fillcolor="#ffffff"]
  }

  // Module: behaviors/
  subgraph cluster_behaviors {
    label="behaviors/" style=filled fillcolor="#eeeeee" color="#999999"
    bhv_expert [label="amplifier-expert.yaml\n(agent + context)" shape=note fillcolor="#ffffff"]
    bhv_dev [label="amplifier-dev.yaml\n(context-only)" shape=note fillcolor="#ffffff"]
  }

  // Module: context/
  subgraph cluster_context {
    label="context/" style=filled fillcolor="#eeeeee" color="#999999"
    ctx_overview [label="ecosystem-overview.md" shape=note fillcolor="#ffffff"]
    ctx_hygiene [label="development-hygiene.md" shape=note fillcolor="#ffffff"]
    ctx_recipes [label="recipes-usage.md" shape=note fillcolor="#ffffff"]
  }

  // Module: docs/
  subgraph cluster_docs {
    label="docs/" style=filled fillcolor="#eeeeee" color="#999999"
    docs_guides [label="README + 8 guides\n(audience-tiered)" shape=note fillcolor="#ffffff"]
    docs_modules [label="MODULES.md\n(ecosystem registry)" shape=cylinder fillcolor="#ffffff"]
    docs_govern [label="REPOSITORY_RULES.md\n(governance)" shape=note fillcolor="#ffffff"]
  }

  // Module: outlines/
  subgraph cluster_outlines {
    label="outlines/" style=filled fillcolor="#eeeeee" color="#999999"
    outline_spec [label="dev-hygiene_outline.json\n(synthesis spec)" shape=note fillcolor="#ffffff"]
  }

  // Module: recipes/
  subgraph cluster_recipes {
    label="recipes/" style=filled fillcolor="#eeeeee" color="#999999"
    rcp_audit [label="audit pair\n(ecosystem + repo)" shape=note fillcolor="#ffffff"]
    rcp_activity [label="activity pair\n(report + analysis)" shape=note fillcolor="#ffffff"]
    rcp_docgen [label="doc-gen pipeline\n(outline + gen)" shape=note fillcolor="#ffffff"]
  }

  // Module: tests/
  subgraph cluster_tests {
    label="tests/" style=filled fillcolor="#eeeeee" color="#999999"
    test_sweep [label="test_doc_sweep.sh" shape=box style="rounded,filled" fillcolor="#ffffff"]
  }

  // Module: assets/ (isolated island)
  subgraph cluster_assets {
    label="assets/ [isolated]" style=filled fillcolor="#f5f5f5" color="#cccccc"
    assets_brand [label="branding/\n(icons, favicons, PWA)\nzero cross-module refs" shape=component fillcolor="#ffffff"]
  }

  // Shared Interfaces (hexagons at boundaries)
  proto_bundle [label="Bundle Declaration\nProtocol" shape=hexagon fillcolor="#ddeeff"]
  proto_ns [label="amplifier:\nNamespace Resolution" shape=hexagon fillcolor="#ddeeff"]

  // Shared Types crossing module lines (orange notes)
  type_modules_md [label="MODULES.md\nregistry format" shape=note fillcolor="#ffe0b2"]
  type_outline_json [label="outline.json\nspec format" shape=note fillcolor="#ffe0b2"]

  // ===========================================================
  // CROSS-MODULE EDGES (primary signal)
  // ===========================================================

  // Root wiring (clean — bundle inclusion protocol)
  bundle_md -> bhv_expert [label="includes" style=dashed color="#2e7d32"]
  bundle_md -> ctx_overview [label="@-inlines" style=dashed color="#2e7d32"]

  // behaviors -> context (clean: namespace-mediated context.include)
  bhv_expert -> ctx_overview [label="context.include" style=dashed color="#2e7d32"]
  bhv_dev -> ctx_hygiene [label="context.include" style=dashed color="#2e7d32"]

  // behaviors -> agents (clean: namespace-mediated agents.include)
  bhv_expert -> agent_expert [label="agents.include" style=dashed color="#2e7d32"]

  // agents -> docs (clean: @-mention lazy read)
  agent_expert -> docs_guides [label="@-mention\nTier 1" style=dashed color="#2e7d32"]
  agent_expert -> docs_modules [label="@-mention" style=dashed color="#2e7d32"]

  // agents -> context (soft ref — on-demand load)
  agent_expert -> ctx_recipes [label="soft ref\n(on demand)" style=dotted color="#888888"]

  // context -> docs (shared registry dependency)
  ctx_recipes -> docs_modules [label="repo discovery\nsource" style=dashed color="#2e7d32"]
  ctx_overview -> docs_modules [label="ecosystem\nregistry ref" style=dashed color="#2e7d32"]

  // outlines -> context (TIGHT: direct target_path production dependency)
  outline_spec -> ctx_hygiene [label="produces\n(target_path)" color="red" fontcolor="red" penwidth=2]

  // outlines -> docs (clean: source extraction for grounding)
  outline_spec -> docs_guides [label="sources from" style=dashed color="#2e7d32"]

  // recipes -> MODULES.md (HIDDEN: runtime fetch bypasses amplifier: namespace)
  rcp_audit -> type_modules_md [label="curl raw.github\n(HTTP fetch)" style=dashed color="#cc6600" fontcolor="#cc6600"]
  rcp_activity -> type_modules_md [label="gh api fetch" style=dashed color="#cc6600" fontcolor="#cc6600"]
  rcp_docgen -> type_modules_md [label="local file read\n(landing_repo_path)" style=dashed color="#cc6600" fontcolor="#cc6600"]
  type_modules_md -> docs_modules [label="format of" style=dashed color="#cc6600"]

  // recipes <-> outline format (pipeline interface — typed contract)
  rcp_docgen -> type_outline_json [label="produces /\nconsumes" style=dashed color="#2e7d32"]
  type_outline_json -> outline_spec [label="same format" style=dashed color="#2e7d32"]

  // tests -> docs + recipes (TIGHT: hardcoded grep paths)
  test_sweep -> docs_guides [label="grep\n(hardcoded path)" color="red" fontcolor="red" penwidth=2]
  test_sweep -> rcp_docgen [label="grep\n(hardcoded path)" color="red" fontcolor="red" penwidth=2]

  // Shared protocols -> implementing modules (dotted, association)
  proto_bundle -> bhv_expert [style=dotted color="#aaaaaa" arrowhead=none]
  proto_bundle -> bhv_dev [style=dotted color="#aaaaaa" arrowhead=none]
  proto_bundle -> bundle_md [style=dotted color="#aaaaaa" arrowhead=none]
  proto_ns -> agent_expert [style=dotted color="#aaaaaa" arrowhead=none]
  proto_ns -> bhv_expert [style=dotted color="#aaaaaa" arrowhead=none]
  proto_ns -> ctx_overview [style=dotted color="#aaaaaa" arrowhead=none]

  // Legend
  subgraph cluster_legend {
    label="Legend" style=filled fillcolor="#f9f9f9" color="#cccccc" fontsize=9
    node [fontsize=8]
    lg_mod [label="Module cluster\n(gray fill)" shape=box style="rounded,filled" fillcolor="#eeeeee"]
    lg_iface [label="Shared interface /\nprotocol" shape=hexagon fillcolor="#ddeeff"]
    lg_type [label="Shared type crossing\nmodule boundary" shape=note fillcolor="#ffe0b2"]
    lg_clean [label="--- clean coupling\n(green, interface-based)" shape=plaintext fillcolor="#f9f9f9"]
    lg_tight [label="--- tight coupling\n(red, direct path dep)" shape=plaintext fillcolor="#f9f9f9"]
    lg_hidden [label="--- hidden coupling\n(orange, runtime URL)" shape=plaintext fillcolor="#f9f9f9"]
    lg_mod -> lg_iface [style=invis]
    lg_iface -> lg_type [style=invis]
    lg_type -> lg_clean [style=invis]
    lg_clean -> lg_tight [style=invis]
    lg_tight -> lg_hidden [style=invis]
  }
}
