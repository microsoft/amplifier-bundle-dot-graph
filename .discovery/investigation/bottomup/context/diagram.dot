digraph context_level {
    graph [
        label="amplifier/context — Documentation Context Layer\nKnowledge Triad: Architecture · Operations · Recipes",
        labelloc=t,
        fontsize=14,
        fontname="Helvetica",
        bgcolor="white",
        rankdir=TB
    ]
    node [fontname="Helvetica", fontsize=11]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ── Three markdown files at this level (blue fill = this-level nodes) ──
    ecosystem_overview [
        label="ecosystem-overview.md\n(6652 bytes)\nArchitectural orientation",
        shape=note, style=filled, fillcolor="#ddeeff"
    ]
    dev_hygiene [
        label="development-hygiene.md\n(6293 bytes)\nInstallation & dev patterns",
        shape=note, style=filled, fillcolor="#ddeeff"
    ]
    recipes_usage [
        label="recipes-usage.md\n(6703 bytes)\nRecipe invocation guide",
        shape=note, style=filled, fillcolor="#ddeeff"
    ]

    // ── Key concepts documented per file ──
    kernel_model [
        label="Kernel (amplifier-core)\n~2600 lines | Mechanisms only",
        shape=component, style=filled, fillcolor="#eeeeee"
    ]
    module_types [
        label="5 Module Types\nProvider / Tool / Orchestrator\nContext / Hook",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    bundle_agents [
        label="Bundles & Agents\nAgents ARE bundles\n(foundation-layer pattern)",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    philosophy [
        label="Design Philosophy\nMechanism not Policy\nRuthless Simplicity\nEvent-First Observability",
        shape=hexagon, style=filled, fillcolor="#eeddff"
    ]
    install_arch [
        label="Install Architecture\nuv tool install\n→ ~/.amplifier/cache/ (running code)",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    settings_hierarchy [
        label="Settings Scope Hierarchy\nlocal > project > global\n(.amplifier/settings.yaml)",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    module_resolution [
        label="Module Resolution Order\n6 levels: env var → workspace\n→ project → user → bundle → cache",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    shadow_envs [
        label="Shadow Environments\nContainerized isolation\n(foundation bundle, Gitea-backed)",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    amplifier_reset [
        label="amplifier reset\nSafe cache clearing + reinstall\nNEVER: rm -rf ~/.amplifier/cache/",
        shape=box, style="rounded,filled", fillcolor="#ffdddd"
    ]
    recipe_invoke [
        label="Recipe Invocation\nSession NL or\namplifier tool invoke recipes",
        shape=box, style="rounded,filled", fillcolor="#fffacc"
    ]
    generic_recipes [
        label="Generic Recipes\nrepo-activity-analysis.yaml\nmulti-repo-activity-report.yaml",
        shape=cylinder, style=filled, fillcolor="#ddffdd"
    ]
    modules_md [
        label="docs/MODULES.md\nEcosystem repo registry\n(canonical repo list)",
        shape=note, style=filled, fillcolor="#ffeecc"
    ]

    // ── File → concept edges ──
    ecosystem_overview -> kernel_model
    ecosystem_overview -> module_types
    ecosystem_overview -> bundle_agents
    ecosystem_overview -> philosophy

    dev_hygiene -> install_arch
    dev_hygiene -> settings_hierarchy
    dev_hygiene -> module_resolution
    dev_hygiene -> shadow_envs
    dev_hygiene -> amplifier_reset

    recipes_usage -> recipe_invoke
    recipes_usage -> generic_recipes
    recipes_usage -> modules_md [label="repo discovery source"]

    // ── Cross-file connections (primary signal at this level) ──
    ecosystem_overview -> dev_hygiene [
        label="arch overview elaborated by\noperational hygiene detail",
        color="#336699", penwidth=2, style=dashed, fontcolor="#336699"
    ]
    ecosystem_overview -> recipes_usage [
        label="recipes mentioned →\nhow-to detail in usage guide",
        color="#336699", penwidth=2, style=dashed, fontcolor="#336699"
    ]
    ecosystem_overview -> modules_md [
        label="ecosystem repo source\n(shared with recipes-usage)",
        color="#669933", penwidth=2, style=dashed, fontcolor="#669933"
    ]
    settings_hierarchy -> module_resolution [
        label="settings scope defines\nresolution priority",
        color="#888888"
    ]

    // ── Legend ──
    subgraph cluster_legend {
        label="Legend"
        fontsize=11
        style=filled
        fillcolor="#f5f5f5"
        node [fontsize=10]

        l_file   [label="context file (.md)",    shape=note,      style=filled,           fillcolor="#ddeeff"]
        l_topic  [label="concept / topic",        shape=box,       style="rounded,filled", fillcolor="#fffacc"]
        l_comp   [label="module / component",     shape=component, style=filled,           fillcolor="#eeeeee"]
        l_proto  [label="interface / philosophy", shape=hexagon,   style=filled,           fillcolor="#eeddff"]
        l_store  [label="data store / registry",  shape=cylinder,  style=filled,           fillcolor="#ddffdd"]
        l_ext    [label="external reference",     shape=note,      style=filled,           fillcolor="#ffeecc"]
        l_warn   [label="critical / warning",     shape=box,       style="rounded,filled", fillcolor="#ffdddd"]

        l_file  -> l_topic  [style=invis]
        l_topic -> l_comp   [style=invis]
        l_comp  -> l_proto  [style=invis]
        l_proto -> l_store  [style=invis]
        l_store -> l_ext    [style=invis]
        l_ext   -> l_warn   [style=invis]
    }
}
