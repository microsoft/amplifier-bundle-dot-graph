digraph docs_level {
  graph [rankdir=TB, fontname="Helvetica", label="docs/ — Audience-Routed Documentation Hub",
         labelloc=t, fontsize=14, compound=true, splines=ortho];
  node [fontname="Helvetica", fontsize=11, style=filled];
  edge [fontname="Helvetica", fontsize=10];

  // ── Hub / Navigation ──────────────────────────────────────────────
  subgraph cluster_hub {
    label="Navigation Hub";
    style=filled; fillcolor="#ddeeff"; color="#aaaacc";

    readme [label="README.md\n(audience router)", shape=note, fillcolor="#ddeeff"];
    modules_cat [label="MODULES.md\n(ecosystem catalog / registry)", shape=cylinder, fillcolor="#ddeeff"];
  }

  // ── User Audience ─────────────────────────────────────────────────
  subgraph cluster_users {
    label="User Audience";
    style=filled; fillcolor="#eeeeee"; color="#aaaaaa";

    onboarding [label="USER_ONBOARDING.md\naudience: user", shape=note, fillcolor="#eeeeee"];
    user_guide [label="USER_GUIDE.md\naudience: user", shape=note, fillcolor="#eeeeee"];
  }

  // ── Developer Audience ────────────────────────────────────────────
  subgraph cluster_developers {
    label="Developer Workflow Triad";
    style=filled; fillcolor="#eeeeee"; color="#aaaaaa";

    developer [label="DEVELOPER.md\n(AI-assisted module creation)", shape=note, fillcolor="#eeeeee"];
    module_dev [label="MODULE_DEVELOPMENT.md\naudience: developer", shape=note, fillcolor="#eeeeee"];
    local_dev  [label="LOCAL_DEVELOPMENT.md\naudience: developer", shape=note, fillcolor="#eeeeee"];
    testing    [label="TESTING_GUIDE.md\naudience: developer", shape=note, fillcolor="#eeeeee"];
  }

  // ── Governance / Architecture ─────────────────────────────────────
  subgraph cluster_governance {
    label="Governance Layer";
    style=filled; fillcolor="#eeeeee"; color="#aaaaaa";

    repo_rules   [label="REPOSITORY_RULES.md\n(awareness hierarchy)", shape=note, fillcolor="#eeeeee"];
    adr_template [label="ADR_TEMPLATE.md\n(decision record template)", shape=note, fillcolor="#eeeeee"];
  }

  // ── README routes to all clusters ─────────────────────────────────
  readme -> onboarding  [label="new users"];
  readme -> user_guide  [label="users"];
  readme -> local_dev   [label="module devs"];
  readme -> module_dev  [label="module devs"];
  readme -> testing     [label="module devs"];
  readme -> repo_rules  [label="contributors"];

  // ── Cross-cluster connections ──────────────────────────────────────
  user_guide  -> onboarding  [label="config deep-dive\n& recovery"];
  user_guide  -> modules_cat [label="available modules"];
  user_guide  -> developer   [label="build your own"];
  developer   -> modules_cat [label="add community module"];

  // ── Developer triad intra-cluster (shared curriculum) ─────────────
  testing    -> module_dev [label="related docs", style=dashed];
  testing    -> local_dev  [label="related docs", style=dashed];
  module_dev -> local_dev  [label="setup prereq", style=dashed];

  // ── Legend ────────────────────────────────────────────────────────
  subgraph cluster_legend {
    label="Legend"; style=filled; fillcolor="#ffffff"; color="#666666";
    rank=sink;

    l_hub  [label="hub / this-level", shape=note,      fillcolor="#ddeeff"];
    l_cat  [label="registry / catalog", shape=cylinder, fillcolor="#ddeeff"];
    l_file [label="grouped file",     shape=note,      fillcolor="#eeeeee"];
    l_dash [label="intra-cluster ref", shape=plaintext, fillcolor="#ffffff"];

    l_hub  -> l_cat  [style=invis];
    l_cat  -> l_file [style=invis];
    l_file -> l_dash [style=invis];
  }
}
