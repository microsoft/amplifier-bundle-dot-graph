digraph outlines_synthesis {
    rankdir=TB
    compound=true
    graph [
        fontname="Helvetica" fontsize=12 bgcolor="white"
        label="outlines/ — Document Synthesis Specification Layer"
        labelloc=t
    ]
    node [fontname="Helvetica" fontsize=11 style=filled]
    edge [fontname="Helvetica" fontsize=10 color="#555555"]

    // ─── This-level artifact ─────────────────────────────────────────────────
    outline_file [
        label="development-hygiene_outline.json\n(15,999 bytes)"
        shape=note
        fillcolor="#ddeeff"
    ]

    // ─── _meta: generation configuration block ───────────────────────────────
    subgraph cluster_meta {
        label="_meta: Generation Configuration"
        style=filled fillcolor="#eeeeee"

        cfg_type  [label="document_type: synthesized"          shape=box      fillcolor="#e8e8e8"]
        cfg_model [label="model: claude-sonnet-4-20250514\ntemp: 0.2"  shape=box fillcolor="#e8e8e8"]
        cfg_repos [label="allowed_source_repos\n(37 ecosystem repos)"  shape=cylinder fillcolor="#e8e8e8"]
    }

    // ─── document: section tree ──────────────────────────────────────────────
    subgraph cluster_sections {
        label="document: 5 Top-Level Sections, 9 Subsections"
        style=filled fillcolor="#eeeeee"

        sec_install  [label="§ How Amplifier\nIs Installed\n(3 subsections)"     shape=box fillcolor="#e8e8e8"]
        sec_cache    [label="§ CRITICAL:\nNever Delete Cache\n(1 subsection)"    shape=box fillcolor="#e8e8e8"]
        sec_patterns [label="§ Development\nPatterns\n(5 subsections)"           shape=box fillcolor="#e8e8e8"]
        sec_summary  [label="§ Summary:\nWhere Things Belong"                    shape=box fillcolor="#e8e8e8"]
    }

    // ─── External grounding sources ──────────────────────────────────────────
    src_local   [label="docs/LOCAL_DEVELOPMENT.md\n(primary — 12 section references)"   shape=note fillcolor="#fff3cd"]
    src_onboard [label="docs/USER_ONBOARDING.md\n(secondary — 4 section references)"    shape=note fillcolor="#fff3cd"]

    // ─── Generated output ────────────────────────────────────────────────────
    tgt_ctx [label="context/development-hygiene.md\n(synthesized agent context output)" shape=note fillcolor="#d4edda"]

    // ─── Connections ─────────────────────────────────────────────────────────
    outline_file -> cfg_type    [lhead=cluster_meta     label="configures"    color="#3355aa" penwidth=2]
    outline_file -> sec_install [lhead=cluster_sections label="defines"       color="#3355aa" penwidth=2]
    outline_file -> tgt_ctx     [label="target output"                        color="#2d7a2d" penwidth=2]

    src_local   -> sec_install  [style=dashed color="#888888" label="grounds"]
    src_local   -> sec_cache    [style=dashed color="#888888"]
    src_local   -> sec_patterns [style=dashed color="#888888"]
    src_local   -> sec_summary  [style=dashed color="#888888"]
    src_onboard -> sec_patterns [style=dashed color="#888888" label="grounds"]
    src_onboard -> sec_summary  [style=dashed color="#888888"]

    cfg_repos   -> sec_install  [lhead=cluster_sections label="scope gate" style=dotted color="#aaaaaa"]

    // ─── Legend ──────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#f9f9f9"
        rank=sink

        ll1 [label="Outline spec file"   shape=note     fillcolor="#ddeeff" fontsize=10]
        ll2 [label="Internal structure"  shape=box      fillcolor="#e8e8e8" fontsize=10]
        ll3 [label="Source reference"    shape=note     fillcolor="#fff3cd" fontsize=10]
        ll4 [label="Generated output"    shape=note     fillcolor="#d4edda" fontsize=10]
        ll5 [label="Repo catalog"        shape=cylinder fillcolor="#e8e8e8" fontsize=10]
    }
}
