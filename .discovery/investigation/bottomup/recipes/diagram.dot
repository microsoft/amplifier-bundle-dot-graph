digraph recipes_level {
    graph [rankdir=LR, fontname="Helvetica", fontsize=11, pad=0.5, compound=true, splines=polyline]
    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9]

    // -------------------------------------------------------------------------
    // GitHub / Ecosystem Analysis Cluster (4 recipes, 2 orchestrator-leaf pairs)
    // -------------------------------------------------------------------------
    subgraph cluster_github {
        label="GitHub / Ecosystem Analysis"
        style=filled
        fillcolor="#f0f0f0"
        color="#888888"

        subgraph cluster_audit_pair {
            label="Compliance Audit Pair"
            style=filled
            fillcolor="#e8f4e8"
            color="#66aa66"

            ecosystem_audit [label="amplifier-ecosystem-audit\nv1.2.0 | 590 lines\nstages: discovery \u2192 audit \u2192 report", shape=note, fillcolor="#ddeeff"]
            repo_audit [label="repo-audit\nv1.2.0 | 903 lines\nleaf: single-repo compliance", shape=note, fillcolor="#ddeeff"]
        }

        subgraph cluster_activity_pair {
            label="Activity Analysis Pair"
            style=filled
            fillcolor="#f4e8e8"
            color="#aa6666"

            ecosystem_activity [label="ecosystem-activity-report\nv1.15.2 | 1487 lines\norchestrator + synthesis", shape=note, fillcolor="#ddeeff"]
            repo_activity [label="repo-activity-analysis\nv3.1.0 | 1189 lines\nleaf: single-repo activity", shape=note, fillcolor="#ddeeff"]
        }
    }

    // -------------------------------------------------------------------------
    // Documentation Generation Pipeline (2 recipes, loose file-handoff coupling)
    // -------------------------------------------------------------------------
    subgraph cluster_docs {
        label="Documentation Generation Pipeline"
        style=filled
        fillcolor="#f0f0f8"
        color="#6666aa"

        outline_gen [label="outline-generation-from-doc\nv1.6.1 | 2277 lines\nproducer: outputs outlines/*.json", shape=note, fillcolor="#ddeeff"]
        doc_gen [label="document-generation\nv8.1.0 | 3021 lines\nconsumer: takes outline_path", shape=note, fillcolor="#ddeeff"]
    }

    // -------------------------------------------------------------------------
    // Shared Foundation Agents (cross-recipe, external to this directory)
    // -------------------------------------------------------------------------
    subgraph cluster_agents {
        label="Shared Foundation Agents (external)"
        style=filled
        fillcolor="#eeeeee"
        color="#aaaaaa"

        zen_architect [label="foundation:zen-architect\n4 of 6 recipes", shape=component, fillcolor="#eeeeee"]
        explorer_agent [label="foundation:explorer\n3 of 6 recipes", shape=component, fillcolor="#eeeeee"]
        di_agents [label="design-intelligence:\nvoice-strategist +\nlayout-architect", shape=component, fillcolor="#eeeeee"]
    }

    // -------------------------------------------------------------------------
    // Shared Infrastructure Annotation
    // -------------------------------------------------------------------------
    shared_infra [label="Shared Infrastructure (all recipes)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nworking_dir context var (6/6)\nretry + exponential backoff (5/6)\ngh CLI + GitHub API (4/6)\nrate_limiting block (2 orchestrators)\nmodel tiering haiku\u2192sonnet\u2192opus (3/6)", shape=box, fillcolor="#ffffd0", color="#cccc00"]

    // -------------------------------------------------------------------------
    // Cross-file Edges (primary signal)
    // -------------------------------------------------------------------------

    // Orchestrator → Leaf: direct type:recipe invocation
    ecosystem_audit -> repo_audit [label="foreach: type=recipe\nrepo_owner, repo_name\ncreate_fix_pr, dry_run", style=bold, color="#336633", penwidth=2]
    ecosystem_activity -> repo_activity [label="foreach: type=recipe\npasses precomputed dates\n(skips 12 redundant LLM calls)", style=bold, color="#993333", penwidth=2]

    // Pipeline: file handoff (loose coupling, separate executions)
    outline_gen -> doc_gen [label="file handoff\n./outlines/*.json\n(separate execution)", style=dashed, color="#333399", penwidth=1.5]

    // Agent usage across recipes (dotted = shared dependency)
    ecosystem_audit -> zen_architect [style=dotted, color="#888888", arrowhead=open]
    ecosystem_activity -> zen_architect [style=dotted, color="#888888", arrowhead=open]
    repo_audit -> zen_architect [style=dotted, color="#888888", arrowhead=open]
    outline_gen -> zen_architect [style=dotted, color="#888888", arrowhead=open]
    doc_gen -> zen_architect [style=dotted, color="#888888", arrowhead=open]
    ecosystem_activity -> explorer_agent [style=dotted, color="#888888", arrowhead=open]
    outline_gen -> explorer_agent [style=dotted, color="#888888", arrowhead=open]
    doc_gen -> explorer_agent [style=dotted, color="#888888", arrowhead=open]
    doc_gen -> di_agents [style=dotted, color="#888888", arrowhead=open]

    // -------------------------------------------------------------------------
    // Legend
    // -------------------------------------------------------------------------
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#ffffff"
        color="#cccccc"

        leg_recipe [label="recipe file\n(this level)", shape=note, fillcolor="#ddeeff"]
        leg_agent [label="external agent\n(summarized)", shape=component, fillcolor="#eeeeee"]
        leg_a [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_b [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_c [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_d [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_e [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_f [label="", shape=point, width=0.01, fillcolor="#ffffff"]
        leg_a -> leg_b [label="type:recipe invocation", style=bold, color="#336633", penwidth=2]
        leg_c -> leg_d [label="file handoff (pipeline)", style=dashed, color="#333399"]
        leg_e -> leg_f [label="shared agent dependency", style=dotted, color="#888888", arrowhead=open]
    }
}
