digraph tests_level {
    graph [
        label="amplifier/tests/ — Level Synthesis"
        labelloc="t"
        fontname="Helvetica"
        fontsize=14
        bgcolor="white"
        rankdir="LR"
    ]
    node [fontname="Helvetica" fontsize=11 style=filled]
    edge [fontname="Helvetica" fontsize=10]

    // This-level file (blue tint)
    test_doc_sweep [
        label="test_doc_sweep.sh\n81 lines\nTask-15 acceptance test"
        shape=note
        fillcolor="#ddeeff"
    ]

    check_fn [
        label="check()\nlocal test helper\nPASS/FAIL counter"
        shape=box
        fillcolor="#ddeeff"
    ]

    // External repo targets probed by the test (gray — outside tests/)
    readme [
        label="README.md\ngpt-5.x model refs"
        shape=note
        fillcolor="#eeeeee"
    ]

    user_guide [
        label="docs/USER_GUIDE.md\ngpt-5.x model refs"
        shape=note
        fillcolor="#eeeeee"
    ]

    recipe_yaml [
        label="recipes/document-generation.yaml\ngpt-4o → gpt-5.4 / gpt-5-mini"
        shape=note
        fillcolor="#eeeeee"
    ]

    // Internal structure
    test_doc_sweep -> check_fn [label="defines + calls"]

    // Cross-repo probes
    check_fn -> readme [label="grep: 3 checks\n(no gpt-5.1/5.2, has gpt-5.4)"]
    check_fn -> user_guide [label="grep: 2 checks\n(no gpt-5.1, has gpt-5.4)"]
    check_fn -> recipe_yaml [label="grep: 4 checks\n(no gpt-4o, has gpt-5.4/gpt-5-mini)"]

    // Legend
    subgraph cluster_legend {
        label="Legend"
        fontsize=11
        style=dashed
        color=gray
        node [margin="0.1,0.05"]
        leg_file [label="this-level file" shape=note fillcolor="#ddeeff"]
        leg_fn [label="function/helper" shape=box fillcolor="#ddeeff"]
        leg_ext [label="external target\n(outside tests/)" shape=note fillcolor="#eeeeee"]
    }
}
