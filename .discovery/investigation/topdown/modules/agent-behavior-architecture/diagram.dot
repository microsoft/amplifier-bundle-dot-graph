digraph agent_behavior_architecture {
  graph [rankdir=TB, fontname="Helvetica", fontsize=14, compound=true,
    label="Agent & Behavior Definition Architecture\n(Synthesized from 8 Investigation Perspectives)",
    labelloc=t, pad=0.5, nodesep=0.6, ranksep=0.8]
  node [fontname="Helvetica", fontsize=10, style=filled]
  edge [fontname="Helvetica", fontsize=8]

  // ===================================================================
  // Root Bundle Entry Point
  // ===================================================================
  bundle_md [label="bundle.md\n(root bundle definition)", shape=house, fillcolor="#B2DFDB"]

  // ===================================================================
  // CLUSTER: Behavior Layer (behaviors/)
  // ===================================================================
  subgraph cluster_behaviors {
    label="behaviors/\n(thin bundle pattern — C-02)"
    style=filled
    fillcolor="#E3F2FD"
    color="#42A5F5"

    bhv_expert [label="amplifier-expert.yaml\n(agent + context)\nActive injection", shape=note, fillcolor="#BBDEFB"]
    bhv_dev [label="amplifier-dev.yaml\n(context-only)\nPassive injection", shape=note, fillcolor="#BBDEFB"]
  }

  // ===================================================================
  // CLUSTER: Agent Definition Layer (agents/)
  // ===================================================================
  subgraph cluster_agents {
    label="agents/\n(single agent — knowledge monopoly X-01)"
    style=filled
    fillcolor="#E8F5E9"
    color="#66BB6A"

    expert_md [label="amplifier-expert.md\n(15.1 KB, sole agent)\nDual-layer: YAML meta + MD body\n(C-01)", shape=doubleoctagon, fillcolor="#C8E6C9"]

    subgraph cluster_modes {
      label="Operating Modes (C-06)\n(trigger-phrase dispatch)"
      style=dashed
      color="#999999"
      fillcolor="#F1F8E9"

      mode_research [label="RESEARCH\n\"what is / how does\"", shape=box, fillcolor="#DCEDC8"]
      mode_guide [label="GUIDE\n\"how should I\"", shape=box, fillcolor="#DCEDC8"]
      mode_validate [label="VALIDATE\n\"is this right\"", shape=box, fillcolor="#DCEDC8"]
    }

    expert_md -> mode_research [style=dashed, color="#888888"]
    expert_md -> mode_guide [style=dashed, color="#888888"]
    expert_md -> mode_validate [style=dashed, color="#888888"]
  }

  // ===================================================================
  // CLUSTER: Context Layer (context/)
  // ===================================================================
  subgraph cluster_context {
    label="context/\nDocumentation Knowledge Triad (C-03)\n(~6.5KB each, balanced token budget — C-08)"
    style=filled
    fillcolor="#FFF3E0"
    color="#FFA726"

    ctx_overview [label="ecosystem-overview.md\n(6.6 KB)\nArchitectural orientation", shape=note, fillcolor="#FFE0B2"]
    ctx_hygiene [label="development-hygiene.md\n(6.3 KB)\nOperational safety", shape=note, fillcolor="#FFE0B2"]
    ctx_recipes [label="recipes-usage.md\n(6.7 KB)\nRecipe invocation", shape=note, fillcolor="#FFE0B2"]
  }

  // ===================================================================
  // CLUSTER: Outline Specification Layer (outlines/)
  // ===================================================================
  subgraph cluster_outlines {
    label="outlines/\n(synthesis spec layer — C-03)"
    style=filled
    fillcolor="#F3E5F5"
    color="#AB47BC"

    outline_hygiene [label="development-hygiene_outline.json\n(16 KB, sole spec)\nLLM config + section tree", shape=note, fillcolor="#E1BEE7"]
  }

  // ===================================================================
  // CLUSTER: Source Documentation (docs/)
  // ===================================================================
  subgraph cluster_docs {
    label="docs/\n(authoritative long-form ~125KB)"
    style=filled
    fillcolor="#ECEFF1"
    color="#78909C"

    doc_local [label="LOCAL_DEVELOPMENT.md\n(primary source — 12 refs)", shape=note, fillcolor="#CFD8DC"]
    doc_onboard [label="USER_ONBOARDING.md\n(secondary — 4 refs)", shape=note, fillcolor="#CFD8DC"]
    doc_rules [label="REPOSITORY_RULES.md\n(governance anchor)", shape=note, fillcolor="#CFD8DC"]
    doc_modules [label="MODULES.md\n(25KB ecosystem registry)", shape=note, fillcolor="#CFD8DC"]
  }

  // ===================================================================
  // CLUSTER: 5-Tier Knowledge Hierarchy
  // ===================================================================
  subgraph cluster_tiers {
    label="5-Tier Knowledge Hierarchy\n(@-mention refs, convention priority — C-04)"
    style=filled
    fillcolor="#FCE4EC"
    color="#E91E63"

    tier0 [label="Tier 0: @core:docs/\namplifier-core kernel", shape=component, fillcolor="#F8BBD0"]
    tier1 [label="Tier 1: @amplifier:docs/\nentry-point docs", shape=component, fillcolor="#F8BBD0"]
    tier2 [label="Tier 2: @foundation:docs/\nfoundation library", shape=component, fillcolor="#F8BBD0"]
    tier3 [label="Tier 3: @foundation:context/\ncore philosophy", shape=component, fillcolor="#F8BBD0"]
    tier4 [label="Tier 4: @recipes:docs/\nworkflow recipes", shape=component, fillcolor="#F8BBD0"]
  }

  // ===================================================================
  // External: Spoke Experts, Shared Protocols, Unknown Deps
  // ===================================================================
  core_expert [label="core:core-expert\n(deep kernel)", shape=hexagon, fillcolor="#FFCDD2"]
  foundation_expert [label="foundation:foundation-expert\n(bundles & examples)", shape=hexagon, fillcolor="#FFCDD2"]
  recipe_author [label="recipes:recipe-author\n(workflows)", shape=hexagon, fillcolor="#FFCDD2"]

  at_mention [label="@-mention Protocol\n(sole delivery — C-07)\nBaseMentionResolver +\nContentDeduplicator\n(lives in amplifier-foundation)", shape=hexagon, fillcolor="#CE93D8"]

  prompt_factory [label="System Prompt Factory\nper-request assembly\n(no caching)", shape=hexagon, fillcolor="#CE93D8"]

  common_base [label="@foundation:context/shared/\ncommon-agent-base.md\n(content unknown — D-03)", shape=note, fillcolor="#FFAB91"]

  // ===================================================================
  // CONSENSUS EDGES (solid — multiple sources agree)
  // ===================================================================

  // Root bundle wiring (C-07)
  bundle_md -> bhv_expert [label="includes\n(C-07)", color="#2E7D32", penwidth=1.5]

  // Behavior -> Agent/Context wiring (C-02)
  bhv_expert -> expert_md [label="agents.include\n(C-02)", color="#2E7D32", penwidth=1.5]
  bhv_expert -> ctx_overview [label="context.include\n(C-02)", color="#2E7D32", penwidth=1.5]
  bhv_dev -> ctx_hygiene [label="context.include\n(C-02)", color="#2E7D32", penwidth=1.5]

  // Content refinement pipeline (C-03)
  doc_local -> outline_hygiene [label="grounds\n(12 refs)", color="#7B1FA2", style=dashed]
  doc_onboard -> outline_hygiene [label="grounds\n(4 refs)", color="#7B1FA2", style=dashed]
  outline_hygiene -> ctx_hygiene [label="produces\n(C-03)", color="#7B1FA2", penwidth=1.5]

  // Agent references to docs namespace (via @-mention)
  expert_md -> doc_rules [label="Tier 1 ref\n(via @amplifier:docs/)", color="#E91E63", style=dashed]
  expert_md -> doc_modules [label="Tier 1 ref\n(via @amplifier:docs/)", color="#E91E63", style=dashed]

  // Expert -> External tier references
  expert_md -> tier0 [label="@core:docs/", color="#E91E63"]
  expert_md -> tier2 [label="@foundation:docs/", color="#E91E63"]
  expert_md -> tier3 [label="@foundation:context/", color="#E91E63"]
  expert_md -> tier4 [label="@recipes:docs/", color="#E91E63"]

  // All tiers resolved via @-mention protocol (C-07)
  at_mention -> tier0 [label="resolves", color="#7B1FA2", style=dashed, dir=back]
  at_mention -> tier1 [color="#7B1FA2", style=dashed, dir=back]

  // @-mention -> prompt factory -> expert (C-05 in expert-knowledge module)
  at_mention -> prompt_factory [label="resolved content", color="#7B1FA2", penwidth=1.5]
  prompt_factory -> expert_md [label="assembled system\nprompt (per-request)", color="#7B1FA2", penwidth=1.5]

  // Expert -> Spoke routing (C-05)
  expert_md -> core_expert [label="delegates kernel\n(C-05)", style=dashed, color="#D32F2F"]
  expert_md -> foundation_expert [label="delegates bundles\n(C-05)", style=dashed, color="#D32F2F"]
  expert_md -> recipe_author [label="delegates workflows\n(C-05)", style=dashed, color="#D32F2F"]

  // Expert -> common base include
  expert_md -> common_base [label="@-include\n(appended)", style=dotted, color="#E64A19"]

  // ===================================================================
  // DISCREPANCY EDGES (dashed/dotted red — unresolved)
  // ===================================================================

  // D-01: amplifier-dev-behavior activation unknown
  bundle_md -> bhv_dev [label="D-01: NOT included\n(orphaned?)", style=dashed, color="red", fontcolor="red", penwidth=1.5]

  // D-02: recipes-usage.md soft reference status
  bhv_expert -> ctx_recipes [label="D-02: soft ref\n(commented out)", style=dotted, color="red", fontcolor="red"]

  // D-04: Eager vs lazy directory loading
  expert_md -> tier0 [label="D-04: eager or\nlazy load?", style=dashed, color="red", fontcolor="red", penwidth=1.5, constraint=false]

  // X-04: Missing outline specs for 2/3 context files
  outline_hygiene -> ctx_overview [label="X-04: no outline\nspec exists", style=dotted, color="red", fontcolor="red", constraint=false]
  outline_hygiene -> ctx_recipes [label="X-04: no outline\nspec exists", style=dotted, color="red", fontcolor="red", constraint=false]

  // ===================================================================
  // LEGEND
  // ===================================================================
  subgraph cluster_legend {
    label="Legend"
    style=filled
    fillcolor=white
    color=black

    node [shape=plaintext, fillcolor=white]
    LEGEND [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2"><B>Edge Styles</B></TD></TR>
      <TR><TD>solid green</TD><TD>Consensus: bundle composition wiring (C-02, C-07)</TD></TR>
      <TR><TD>solid purple</TD><TD>Consensus: content pipeline / @-mention delivery (C-03, C-07)</TD></TR>
      <TR><TD>solid pink</TD><TD>Consensus: knowledge tier references (C-01)</TD></TR>
      <TR><TD>dashed red (thin)</TD><TD>Consensus: convention-based routing (C-05)</TD></TR>
      <TR><TD>dashed red (thick)</TD><TD>Open discrepancy (D-01, D-02, D-04)</TD></TR>
      <TR><TD>dotted red</TD><TD>Cross-cutting gap (X-04)</TD></TR>
      <TR><TD>dotted orange</TD><TD>Unknown content dependency (D-03)</TD></TR>
      <TR><TD COLSPAN="2"><B>Node Shapes</B></TD></TR>
      <TR><TD BGCOLOR="#C8E6C9">doubleoctagon</TD><TD>Hub agent (sole ecosystem router)</TD></TR>
      <TR><TD BGCOLOR="#FFCDD2">hexagon (red)</TD><TD>Spoke expert (external agent)</TD></TR>
      <TR><TD BGCOLOR="#CE93D8">hexagon (purple)</TD><TD>Shared protocol / interface</TD></TR>
      <TR><TD BGCOLOR="#F8BBD0">component</TD><TD>Knowledge tier (external namespace)</TD></TR>
      <TR><TD BGCOLOR="#BBDEFB">note (blue)</TD><TD>Behavior bundle definition</TD></TR>
      <TR><TD BGCOLOR="#FFE0B2">note (orange)</TD><TD>Context document</TD></TR>
      <TR><TD BGCOLOR="#B2DFDB">house</TD><TD>Root bundle definition</TD></TR>
      <TR><TD BGCOLOR="#E1BEE7">note (purple)</TD><TD>Outline specification</TD></TR>
      <TR><TD BGCOLOR="#FFAB91">note (salmon)</TD><TD>Unexamined dependency</TD></TR>
    </TABLE>>]
  }
}
