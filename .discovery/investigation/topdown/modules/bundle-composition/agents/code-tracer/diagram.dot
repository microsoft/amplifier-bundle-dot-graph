digraph bundle_composition {
    label="Entry Point Bundle Composition: Call Graph"
    labelloc=t
    rankdir=TB
    compound=true
    fontname="Helvetica"
    node [fontname="Helvetica" fontsize=11 style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=9 color="#555555"]

    // ── Entry Point ──────────────────────────────────────────
    subgraph cluster_entry {
        label="Entry Point"
        style=filled
        fillcolor="#E8F0FE"
        node [fillcolor="#BBDEFB"]

        BundleMD      [label="amplifier/bundle.md\n(YAML frontmatter + markdown)" shape=note]
        LoadBundle    [label="load_bundle(source)\nregistry.py:1267"]
    }

    // ── Bundle Registry ───────────────────────────────────────
    subgraph cluster_registry {
        label="BundleRegistry  (registry.py)"
        style=filled
        fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]

        LoadSingle    [label="_load_single(uri)\nregistry.py:348"]
        LoadFromPath  [label="_load_from_path(path)\nregistry.py:574"]
        LoadMarkdown  [label="_load_markdown_bundle(path)\nregistry.py:604"]
        LoadYAML      [label="_load_yaml_bundle(path)\nregistry.py:614"]
        ComposeIncl   [label="_compose_includes(bundle)\nregistry.py:622"]
        PreloadNS     [label="_preload_namespace_bundles()\nregistry.py:773"]
        ParseIncl     [label="_parse_include(include)\nregistry.py:963"]
        ResolveIS     [label="_resolve_include_source(src)\nregistry.py:840"]
        NestDetect    [label="Nested Bundle Detection\n(walk up dir tree)\nregistry.py:427"]
    }

    // ── Source Resolution ─────────────────────────────────────
    subgraph cluster_sources {
        label="SimpleSourceResolver  (sources/resolver.py)"
        style=filled
        fillcolor="#FFF9C4"
        node [fillcolor="#FFF59D"]

        SSResolve     [label="SimpleSourceResolver.resolve(uri)\nresolver.py:63"]
        GitHandler    [label="GitSourceHandler\n(git+https://, clones to cache)" shape=component]
        FileHandler   [label="FileSourceHandler\n(file://, local paths)" shape=component]
        HttpHandler   [label="HttpSourceHandler\n(https://)" shape=component]
        ZipHandler    [label="ZipSourceHandler\n(zip+https://)" shape=component]
    }

    // ── Bundle Dataclass ──────────────────────────────────────
    subgraph cluster_bundle {
        label="Bundle Dataclass  (bundle.py)"
        style=filled
        fillcolor="#FCE4EC"
        node [fillcolor="#F8BBD9"]

        ParseFM       [label="parse_frontmatter(content)\nio/frontmatter.py"]
        BundleFromDict [label="Bundle.from_dict(data, base_path)\nbundle.py:531"]
        ParseCtx      [label="_parse_context()\nbundle.py:667"]
        ParseAgents   [label="_parse_agents()\nbundle.py:582"]
        ValidateML    [label="_validate_module_list()\nbundle.py:710"]
        BundleCompose [label="Bundle.compose(*others)\nbundle.py:98"]
        DeepMerge     [label="deep_merge(session, spawn)\ndicts/merge.py"]
        MergeMods     [label="merge_module_lists(providers, tools, hooks)\ndicts/merge.py"]
    }

    // ── Activation Layer ─────────────────────────────────────
    subgraph cluster_activation {
        label="Activation Layer  (bundle.py + modules/activator.py)"
        style=filled
        fillcolor="#F3E5F5"
        node [fillcolor="#E1BEE7"]

        BundlePrepare [label="Bundle.prepare(install_deps)\nbundle.py:245"]
        ModActivator  [label="ModuleActivator.activate_all()\nmodules/activator.py"]
        ActivatePkg   [label="activate_bundle_package()\nmodules/activator.py"]
        BMResolver    [label="BundleModuleResolver\nbundle.py:780\n(module_id → Path)"]
        PrepBundle    [label="PreparedBundle\nbundle.py:903\n(mount_plan + resolver)"]
    }

    // ── Session Layer ─────────────────────────────────────────
    subgraph cluster_session {
        label="Session Layer  (bundle.py + amplifier-core)"
        style=filled
        fillcolor="#E0F2F1"
        node [fillcolor="#B2DFDB"]

        CreateSession [label="PreparedBundle.create_session()\nbundle.py:1043"]
        AmpSession    [label="AmplifierSession(mount_plan)\nsession.py:30"]
        MountResolver [label="coordinator.mount(\n'module-source-resolver', resolver)\nbundle.py:1095"]
        SessInit      [label="session.initialize()\nsession.py:110"]
        InitSession   [label="initialize_session(config, coord)\n_session_init.py:22"]
        ResolvePCtx   [label="bundle.resolve_pending_context()\nbundle.py:1118"]
        SPFactory     [label="set_system_prompt_factory(factory)\nbundle.py:1153"]
    }

    // ── Module Loading ────────────────────────────────────────
    subgraph cluster_modload {
        label="Module Loading  (loader.py)"
        style=filled
        fillcolor="#FFF3E0"
        node [fillcolor="#FFE0B2"]

        LoaderLoad    [label="ModuleLoader.load(\n  module_id, config, source_hint)\nloader.py:176"]
        AsyncResolve  [label="BundleModuleResolver.async_resolve()\nbundle.py:833\n(fast-path or lazy activation)"]
        SysPathInj    [label="sys.path.insert(0, module_path)\nloader.py:256"]
        TransportDisp [label="Transport Dispatch\nloader.py:262\n[Python | WASM | gRPC]"]
        Validate      [label="_validate_module()\nloader.py:525"]
        MountFn       [label="mount_fn(coordinator)\n→ module mounted"]
    }

    // ── Legend ────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#F5F5F5"
        node [width=1.8 fontsize=9]
        L_entry  [label="Entry / Trigger"        fillcolor="#BBDEFB" shape=box]
        L_reg    [label="Registry operation"     fillcolor="#C8E6C9" shape=box]
        L_src    [label="Source resolution"      fillcolor="#FFF59D" shape=box]
        L_bun    [label="Bundle dataclass"       fillcolor="#F8BBD9" shape=box]
        L_act    [label="Activation / Install"   fillcolor="#E1BEE7" shape=box]
        L_sess   [label="Session creation"       fillcolor="#B2DFDB" shape=box]
        L_mod    [label="Module loading / mount" fillcolor="#FFE0B2" shape=box]
        L_entry -> L_reg   [style=invis]
        L_reg   -> L_src   [style=invis]
        L_src   -> L_bun   [style=invis]
        L_bun   -> L_act   [style=invis]
        L_act   -> L_sess  [style=invis]
        L_sess  -> L_mod   [style=invis]
    }

    // ─── Edges ────────────────────────────────────────────────

    // Entry
    BundleMD   -> LoadBundle  [label="user calls"]
    LoadBundle -> LoadSingle  [label="delegates to"]

    // Registry load flow
    LoadSingle  -> SSResolve    [label="resolve URI" lhead=cluster_sources]
    LoadSingle  -> LoadFromPath
    LoadFromPath -> LoadMarkdown [label=".md"]
    LoadFromPath -> LoadYAML     [label=".yaml"]
    LoadMarkdown -> ParseFM
    LoadMarkdown -> BundleFromDict [label="Bundle.from_dict()"]
    LoadYAML    -> BundleFromDict
    LoadSingle  -> NestDetect   [label="detect root bundle"]
    LoadSingle  -> ComposeIncl  [label="if includes:"]

    // Parsing
    ParseFM     -> BundleFromDict [label="frontmatter"]
    BundleFromDict -> ValidateML [label="providers/tools/hooks"]
    BundleFromDict -> ParseCtx
    BundleFromDict -> ParseAgents

    // Include composition
    ComposeIncl -> PreloadNS   [label="1. preload namespaces"]
    ComposeIncl -> ParseIncl   [label="2. parse each include"]
    ParseIncl   -> ResolveIS   [label="resolve source"]
    ResolveIS   -> SSResolve   [label="git+https:// or file://"]
    ComposeIncl -> LoadSingle  [label="3. asyncio.gather()\n(PARALLEL)" style=dashed color="#1565C0"]
    ComposeIncl -> BundleCompose [label="4. compose()"]

    // Source handlers
    SSResolve -> GitHandler  [label="git+https://"]
    SSResolve -> FileHandler [label="file://"]
    SSResolve -> HttpHandler [label="https://"]
    SSResolve -> ZipHandler  [label="zip+https://"]

    // Bundle compose internals
    BundleCompose -> DeepMerge  [label="session/spawn"]
    BundleCompose -> MergeMods  [label="providers/tools/hooks"]

    // Activation
    BundleCompose -> BundlePrepare [label="composed bundle → prepare()"]
    BundlePrepare -> ActivatePkg   [label="install bundle pkgs"]
    BundlePrepare -> ModActivator  [label="activate all modules"]
    ModActivator  -> SSResolve     [label="download each module"]
    BundlePrepare -> BMResolver    [label="create resolver"]
    BundlePrepare -> PrepBundle    [label="returns"]

    // Session creation
    PrepBundle   -> CreateSession  [label="app calls create_session()"]
    CreateSession -> AmpSession    [label="new"]
    CreateSession -> MountResolver [label="mount resolver"]
    CreateSession -> SessInit      [label="await initialize()"]
    SessInit     -> InitSession    [label="delegates"]
    CreateSession -> ResolvePCtx
    CreateSession -> SPFactory

    // Module loading
    InitSession  -> LoaderLoad  [label="orchestrator\ncontext\nproviders\ntools\nhooks"]
    LoaderLoad   -> AsyncResolve [label="resolve path"]
    AsyncResolve -> ModActivator [label="lazy activate\n(if missing)" style=dashed]
    LoaderLoad   -> SysPathInj
    LoaderLoad   -> TransportDisp [label="Python|WASM|gRPC"]
    LoaderLoad   -> Validate
    LoaderLoad   -> MountFn     [label="mount_fn(coordinator)"]
}
