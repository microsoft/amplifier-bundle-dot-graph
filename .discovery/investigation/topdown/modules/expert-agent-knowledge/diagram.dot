digraph expert_agent_knowledge {
  graph [rankdir=TB, fontname="Helvetica", fontsize=14, compound=true,
    label="Expert Agent Knowledge Architecture\n(Synthesis — Consensus View)",
    labelloc=t, pad=0.5, nodesep=0.6, ranksep=0.8]
  node [fontname="Helvetica", fontsize=10, style=filled]
  edge [fontname="Helvetica", fontsize=8]

  // === ENTRY POINT ===
  bundle_md [label="bundle.md\n(composition root)", shape=folder, fillcolor="#B3E5FC"]

  // === CLUSTER: Agent Definition ===
  subgraph cluster_agent {
    label="agents/"
    style=filled; fillcolor="#E8F5E9"; color="#66BB6A"
    expert_md [label="amplifier-expert.md\n(15.1KB, sole agent)\nHub / Ecosystem Router", shape=doubleoctagon, fillcolor="#C8E6C9"]
    subgraph cluster_modes {
      label="Operating Modes (C-08)"; style=dashed; color="#999999"; fillcolor="#F1F8E9"
      mode_research [label="RESEARCH\n'what is/how does'", shape=box, fillcolor="#DCEDC8"]
      mode_guide [label="GUIDE\n'how should I'", shape=box, fillcolor="#DCEDC8"]
      mode_validate [label="VALIDATE\n'is this right'", shape=box, fillcolor="#DCEDC8"]
    }
    expert_md -> mode_research [style=dashed, color="#888888", label="trigger-phrase"]
    expert_md -> mode_guide [style=dashed, color="#888888"]
    expert_md -> mode_validate [style=dashed, color="#888888"]
  }

  // === CLUSTER: Behavior Layer ===
  subgraph cluster_behaviors {
    label="behaviors/"; style=filled; fillcolor="#E3F2FD"; color="#42A5F5"
    bhv_expert [label="amplifier-expert.yaml\n(agent+context) Active\n348B, 13 lines", shape=note, fillcolor="#BBDEFB"]
    bhv_dev [label="amplifier-dev.yaml\n(context-only) Passive\n202B, 8 lines\n[D-04: activation unknown]", shape=note, fillcolor="#BBDEFB", peripheries=2]
  }

  // === CLUSTER: Context Layer ===
  subgraph cluster_context {
    label="context/ — Knowledge Triad (C-09)\n~6.5KB each, deliberately balanced"
    style=filled; fillcolor="#FFF3E0"; color="#FFA726"
    ctx_overview [label="ecosystem-overview.md\n(6,652B) Orientation", shape=note, fillcolor="#FFE0B2"]
    ctx_hygiene [label="development-hygiene.md\n(6,293B) Safety", shape=note, fillcolor="#FFE0B2"]
    ctx_recipes [label="recipes-usage.md\n(6,703B) Recipes", shape=note, fillcolor="#FFE0B2"]
  }

  // === CLUSTER: Outlines ===
  subgraph cluster_outlines {
    label="outlines/ (X-04: 1 of 3 specs)"; style=filled; fillcolor="#F5F5F5"; color="#BDBDBD"
    outline_spec [label="development-hygiene\n_outline.json\n(15,999B)", shape=note, fillcolor="#E0E0E0"]
    missing_outlines [label="2 missing specs\n(ecosystem-overview,\nrecipes-usage)", shape=plaintext, fontcolor="#999999"]
  }

  // === CLUSTER: 5-Tier Knowledge Hierarchy ===
  subgraph cluster_tiers {
    label="5-Tier Knowledge Hierarchy (C-01)\n28 @-mentions (10 dir + 18 file)\nNo runtime enforcement (C-03)"
    style=filled; fillcolor="#F3E5F5"; color="#AB47BC"
    tier0 [label="T0: @core:docs/\n+ @core:docs/specs/\nKernel (~2600 lines)", shape=component, fillcolor="#E1BEE7"]
    tier1 [label="T1: @amplifier:docs/\nEntry-point (6 file refs)", shape=component, fillcolor="#E1BEE7"]
    tier2 [label="T2: @foundation:docs/\n+ examples/ + behaviors/\n+ agents/ (4 file refs)", shape=component, fillcolor="#E1BEE7"]
    tier3 [label="T3: @foundation:context/\nPhilosophy (4 file refs)", shape=component, fillcolor="#E1BEE7"]
    tier4 [label="T4: @recipes:docs/\n+ @recipes:examples/\nWorkflows", shape=component, fillcolor="#E1BEE7"]
  }

  // === SPOKE EXPERTS (external) ===
  core_expert [label="core:core-expert\n(kernel contracts)", shape=hexagon, fillcolor="#FFCDD2"]
  foundation_expert [label="foundation:foundation-expert\n(bundle composition)", shape=hexagon, fillcolor="#FFCDD2"]
  recipe_author [label="recipes:recipe-author\n(workflows)", shape=hexagon, fillcolor="#FFCDD2"]

  // === EXTERNAL PROTOCOLS ===
  at_mention [label="@-mention Protocol (C-05)\nparse_mentions() -> resolver\nSole delivery mechanism", shape=hexagon, fillcolor="#CE93D8"]
  common_agent_base [label="common-agent-base.md\n[D-03: content unexamined]", shape=note, fillcolor="#FFAB91"]
  common_system_base [label="common-system-base.md\n[D-03: content unexamined]", shape=note, fillcolor="#FFAB91"]

  // === CONSENSUS EDGES (solid) — verified wiring ===
  bundle_md -> bhv_expert [label="includes (bundle.md:9)", color="#1565C0", penwidth=1.5]
  bundle_md -> common_system_base [label="@-include (bundle.md:90)", style=dotted, color="#E64A19"]
  bhv_expert -> expert_md [label="agents.include (C-04)", color="#2E7D32", penwidth=1.5]
  bhv_expert -> ctx_overview [label="context.include (C-04)", color="#2E7D32", penwidth=1.5]
  bhv_dev -> ctx_hygiene [label="context.include (C-04)", color="#2E7D32", penwidth=1.5]

  // Outline pipeline
  outline_spec -> ctx_hygiene [label="produces (C-06)", color="#E65100", penwidth=1.5]
  missing_outlines -> ctx_overview [label="no spec", style=dashed, color="#BDBDBD"]
  missing_outlines -> ctx_recipes [label="no spec", style=dashed, color="#BDBDBD"]

  // Tier references from expert
  expert_md -> tier0 [color="#7B1FA2"]
  expert_md -> tier1 [color="#7B1FA2"]
  expert_md -> tier2 [color="#7B1FA2"]
  expert_md -> tier3 [color="#7B1FA2"]
  expert_md -> tier4 [color="#7B1FA2"]

  // Hub-and-spoke delegation (convention-based)
  expert_md -> core_expert [label="delegates (C-02)\nline 75, 356", style=dashed, color="#D32F2F"]
  expert_md -> foundation_expert [label="delegates (C-02)\nline 114, 357", style=dashed, color="#D32F2F"]
  expert_md -> recipe_author [label="delegates (C-02)\nline 358", style=dashed, color="#D32F2F"]

  // Common base include
  expert_md -> common_agent_base [label="@-include (line 389)", style=dotted, color="#E64A19"]

  // @-mention protocol resolves tiers
  at_mention -> tier0 [label="resolves", color="#7B1FA2", style=dashed]

  // === DISCREPANCY EDGES (red, dashed/dotted) ===
  at_mention -> tier2 [label="D-01: eager/lazy?\n~20KB vs ~200KB", style=dashed, color=red, fontcolor=red, penwidth=2.0]
  bhv_expert -> ctx_recipes [label="D-02: demoted\nto on-demand?", style=dotted, color=red, fontcolor=red]
  bundle_md -> bhv_dev [label="D-04: no reference\nfound — orphaned?", style=dotted, color=red, fontcolor=red, constraint=false]

  // === CROSS-CUTTING INSIGHT EDGES ===
  ctx_overview -> expert_md [label="X-02: token cost\nunmeasured", style=dashed, color="#FF6F00", fontcolor="#FF6F00", constraint=false]

  // === LEGEND ===
  subgraph cluster_legend {
    label="Legend"; style=filled; fillcolor=white; color=black
    node [shape=plaintext, fillcolor=white]
    LEGEND [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3">
      <TR><TD COLSPAN="2"><B>Edge Styles</B></TD></TR>
      <TR><TD>Solid blue/green</TD><TD>Composition wiring (C-04)</TD></TR>
      <TR><TD>Solid purple</TD><TD>@-mention tier reference (C-01/C-05)</TD></TR>
      <TR><TD>Solid orange</TD><TD>Outline pipeline (C-06)</TD></TR>
      <TR><TD>Dashed red (thin)</TD><TD>Convention-based routing (C-02)</TD></TR>
      <TR><TD>Dotted orange</TD><TD>Common-base include (C-10)</TD></TR>
      <TR><TD BGCOLOR="#FFD0D0">Red dashed/dotted</TD><TD>Open discrepancy (D-nn)</TD></TR>
      <TR><TD>Dashed amber</TD><TD>Cross-cutting insight (X-nn)</TD></TR>
      <TR><TD COLSPAN="2"><B>Node Shapes</B></TD></TR>
      <TR><TD BGCOLOR="#C8E6C9">doubleoctagon</TD><TD>Hub agent (sole)</TD></TR>
      <TR><TD BGCOLOR="#FFCDD2">hexagon</TD><TD>External agent/protocol</TD></TR>
      <TR><TD BGCOLOR="#E1BEE7">component</TD><TD>Knowledge tier (cross-repo)</TD></TR>
      <TR><TD BGCOLOR="#FFAB91">note (salmon)</TD><TD>Unexamined dependency</TD></TR>
      <TR><TD>double-border note</TD><TD>Activation-unknown artifact</TD></TR>
    </TABLE>>]
  }
}
