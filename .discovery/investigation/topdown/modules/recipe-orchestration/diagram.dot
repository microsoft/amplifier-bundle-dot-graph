digraph recipe_orchestration_synthesis {
    graph [label="Recipe Orchestration Patterns — Multi-Perspective Synthesis\ncode-tracer + integration-mapper + bottom-up + discovery-pipeline + subsystem", fontsize=14, rankdir=TB, compound=true, nodesep=0.5, ranksep=0.8]
    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=8]

    // === EXECUTOR ENGINE (HIGH — code-tracer + integration-mapper) ===
    subgraph cluster_engine {
        label="Executor Engine (executor.py, 2750+ lines)"
        style=filled
        fillcolor="#EDF7ED"
        node [shape=box, fillcolor="#A8D8A8"]

        execute_recipe [label="execute_recipe()\nflat/staged routing"]
        exec_staged [label="_execute_staged\n_recipe()"]
        exec_step [label="execute_step()\nspawn agent"]
        exec_bash [label="_execute_bash\n_step()"]
        exec_recipe_step [label="_execute_recipe\n_step() — recurse"]
        exec_loop [label="_execute_loop()\nforeach/while"]
        expr_eval [label="evaluate_condition()\nrecursive descent\n(no eval())", fillcolor="#FFD0A0"]
        rate_limiter [label="RateLimiter\nsemaphore+backoff", fillcolor="#BBBBEE"]
    }

    // === SESSION PERSISTENCE (HIGH — both agents) ===
    subgraph cluster_session {
        label="Session Persistence (session.py)"
        style=filled
        fillcolor="#F3ECFA"
        node [shape=cylinder, fillcolor="#D4AAEE"]

        session_mgr [label="SessionManager"]
        state_json [label="state.json\ncheckpoint"]
        approval_state [label="Approval\nState"]
    }

    // === REAL RECIPE PATTERNS (HIGH — bottom-up) ===
    subgraph cluster_patterns {
        label="Production Recipe Patterns (6 recipes, 386KB total)"
        style=filled
        fillcolor="#E8F4FD"
        node [shape=note, fillcolor="#B8D8F8"]

        orch_worker [label="Orchestrator/Worker Pairs\naudit: ecosystem→repo (parallel:2)\nactivity: ecosystem→repo (parallel:1)"]
        doc_pipeline [label="Document Generation Pipeline\noutline-gen → doc-gen\nmanual handoff via outline.json"]
        model_tiers [label="Model Tier Convention\nhaiku: parsing\nsonnet: analysis\nopus: generation\n(copy-pasted, no central def)"]
        quality_gate [label="Quality Gate Loop\nwhile(true) + break_when\nmax 3 iterations\n(emergent pattern)"]
    }

    // === KERNEL / COORDINATOR (HIGH — both + subsystem) ===
    subgraph cluster_kernel {
        label="Kernel / Coordinator (amplifier-core)"
        style=filled
        fillcolor="#FFF3E0"
        node [shape=diamond, fillcolor="#FFE0B2"]

        session_spawn [label="session.spawn\n(1 formal capability)"]
        coord_surfaces [label="9+ getattr() surfaces\ncancellation | hooks | config\ndisplay | routing | bundles\n(invisible coupling)", fillcolor="#FFCDD2", style="filled,dashed"]
    }

    // === EXTERNAL BOUNDARIES ===
    subgraph cluster_external {
        label="External Boundaries"
        style=filled
        fillcolor="#F5F5F5"
        node [shape=box3d, fillcolor="#CCCCCC", style="filled,dashed"]

        bash_proc [label="/bin/bash\nsubprocess"]
        sub_recipe [label="Child Recipe\n(recursive)"]
        agents [label="Foundation Agents\nzen-architect (ALL 6)\nexplorer (4 of 6)"]
        filesystem [label="Filesystem Data Bus\n./ai_working/\n_precomputed convention"]
    }

    // === CONTEXT DICT (cross-cutting — all perspectives) ===
    context_dict [label="Context Dict\n(overloaded medium)\nexecution state | data bus\ntemplate store | checkpoint\ncross-recipe interface", shape=hexagon, fillcolor="#ce93d8"]

    // === LEGEND ===
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#FAFAFA"
        fontsize=9
        node [shape=box, fontsize=8]

        l_high [label="Solid = HIGH confidence\n(2+ perspectives agree)", fillcolor="#A8D8A8"]
        l_med [label="Dashed = MEDIUM confidence\n(single-source)", fillcolor="#FFFFFF", style="filled,dashed"]
        l_disc [label="Red dashed = Open discrepancy\nor boundary tension", fillcolor="#FFCDD2"]
        l_conv [label="Purple = Convention-based\n(no code enforcement)", fillcolor="#ce93d8"]
        l_high -> l_med -> l_disc -> l_conv [style=invis]
    }

    // ===== EDGES: Engine dispatch (HIGH — code-tracer + integration-mapper) =====
    execute_recipe -> exec_staged [label="staged=true"]
    execute_recipe -> exec_step [label="type=agent"]
    execute_recipe -> exec_bash [label="type=bash"]
    execute_recipe -> exec_recipe_step [label="type=recipe"]
    execute_recipe -> exec_loop [label="foreach/while"]
    execute_recipe -> expr_eval [label="condition"]
    exec_staged -> approval_state [label="gate pause\n[C-07]"]
    exec_step -> rate_limiter [label="acquire"]

    // ===== EDGES: Kernel integration (HIGH — both + subsystem) =====
    exec_step -> session_spawn [label="get_capability()\n[C-01]", color="#FF9800", penwidth=2]
    exec_step -> agents [label="spawn session", color="#4CAF50"]
    execute_recipe -> coord_surfaces [label="getattr() x9+\n[C-12]", style=dashed, color="#F44336", penwidth=1.5]

    // ===== EDGES: Context flow (HIGH — all perspectives) =====
    execute_recipe -> context_dict [label="read/write\nper step", dir=both]
    context_dict -> exec_step [label="template\nsubstitution"]
    context_dict -> state_json [label="checkpoint\n(>100KB trimmed)\n[C-09]"]
    state_json -> context_dict [label="resume\n(placeholders?)\n[OQ-02]", style=dashed, color="#F44336"]

    // ===== EDGES: Sub-recipe (HIGH — code-tracer + bottom-up) =====
    exec_recipe_step -> sub_recipe [label="recurse\n[C-15 output delta]"]
    exec_recipe_step -> execute_recipe [label="recursive call", style=dashed, color="#666666"]

    // ===== EDGES: Bash (HIGH — code-tracer + discovery-pipeline) =====
    exec_bash -> bash_proc [label="asyncio subprocess"]

    // ===== EDGES: Session persistence (HIGH — both agents) =====
    session_mgr -> state_json [dir=both, label="save/load"]
    session_mgr -> approval_state [label="manage"]

    // ===== EDGES: Real recipe patterns (HIGH — bottom-up) =====
    orch_worker -> exec_loop [label="foreach + type:recipe", color="#2196F3", penwidth=1.5]
    orch_worker -> rate_limiter [label="orchestrator\nowns throttling", color="#2196F3"]
    doc_pipeline -> filesystem [label="manual handoff\noutline.json", color="#795548", style=dashed]
    model_tiers -> exec_step [label="per-step provider\npreferences", color="#9C27B0", style=dashed]
    quality_gate -> exec_loop [label="while + break_when\nmax_while_iterations", color="#2196F3"]

    // ===== EDGES: Filesystem coordination (HIGH — 3 perspectives) =====
    context_dict -> filesystem [label="_precomputed\nconvention [F-04]", style=dashed, color="#795548"]
    exec_bash -> filesystem [label="write results", style=dashed, color="#795548"]

    // ===== EDGES: Boundary tensions (RED — open discrepancies) =====
    context_dict -> bash_proc [label="TENSION [C-06]:\nlarge JSON + escaping\nbreaks bash", color="#F44336", style=dashed, penwidth=1.5, constraint=false]
    exec_loop -> approval_state [label="TENSION [D-03]:\nparallel+approval\nundefined", color="#F44336", style=dashed, penwidth=1.5, constraint=false]
    approval_state -> state_json [label="TENSION [D-04]:\ntwo-phase commit\ncross-session resume?", color="#F44336", style=dashed, penwidth=1.5, constraint=false]
}
