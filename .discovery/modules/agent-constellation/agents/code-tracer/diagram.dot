digraph agent_constellation {
    label="Agent Constellation — Roles and Relationships"
    labelloc=t
    rankdir=LR
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    subgraph cluster_general {
        label="General DOT Agents"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]
        DotAuthor      [label="dot-author\nCreates DOT from scratch\nApplies patterns+quality"]
        DiagramReviewer [label="diagram-reviewer\nReviews DOT quality\nChecks standards"]
    }

    subgraph cluster_discovery {
        label="Discovery Pipeline Agents (Triplicate Investigation)"
        style=filled fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]

        subgraph cluster_scope {
            label="Scoping (Stage 1)"
            style=filled fillcolor="#C8E6C9"
            node [fillcolor="#A5D6A7"]
            Prescan [label="discovery-prescan\nTopic selector\nOutputs: JSON array"]
        }

        subgraph cluster_triplicate {
            label="Triplicate Investigation (Stage 2)"
            style=filled fillcolor="#DCEDC8"
            node [fillcolor="#C5E1A5"]
            CodeTracer   [label="discovery-code-tracer\nHOW agent\nLSP + filesystem\nOutputs: findings.md\ndiagram.dot, unknowns.md"]
            BehObserver  [label="discovery-behavior-observer\nWHAT agent\n10+ instances\n[deep only]\nOutputs: catalog.md\npatterns.md, diagram.dot"]
            IntMapper    [label="discovery-integration-mapper\nWHERE/WHY agent\nBoundary focus\nOutputs: integration-map.md\ndiagram.dot, unknowns.md"]
        }

        subgraph cluster_synthesis {
            label="Synthesis (Stage 3)"
            style=filled fillcolor="#F3E5F5"
            node [fillcolor="#E1BEE7"]
            Synthesizer  [label="discovery-synthesizer\nConsensus builder\nCardinal rule: no fiat\nOutputs: diagram.dot\nfindings.md"]
        }
    }

    // Discovery flow
    Prescan -> CodeTracer [label="selects topics"]
    Prescan -> IntMapper [label="selects topics"]
    CodeTracer -> Synthesizer [label="findings feed"]
    BehObserver -> Synthesizer [label="findings feed"]
    IntMapper -> Synthesizer [label="findings feed"]

    // Shared knowledge
    Skills [label="5 Skills\n(patterns, syntax,\nquality, intelligence,\nas-analysis)" shape=note fillcolor="#FFF9C4"]

    DotAuthor -> Skills [label="uses" style=dashed]
    DiagramReviewer -> Skills [label="uses" style=dashed]
    CodeTracer -> Skills [label="uses" style=dashed]
    Synthesizer -> Skills [label="uses" style=dashed]

    // Legend
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.5]
        L_gen  [label="General agent" fillcolor="#BBDEFB"]
        L_disc [label="Discovery agent" fillcolor="#C8E6C9"]
        L_know [label="Knowledge" shape=note fillcolor="#FFF9C4"]
        L_gen -> L_disc [style=invis]
        L_disc -> L_know [style=invis]
    }
}
