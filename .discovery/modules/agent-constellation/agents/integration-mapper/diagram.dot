digraph agent_integration {
    label="Agent Constellation — Integration Boundaries"
    labelloc=t
    rankdir=LR
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10]

    Recipe [label="Recipe Engine\n(orchestrator)" shape=ellipse fillcolor="#C8E6C9"]
    FS     [label="File System\n(.discovery/)" shape=cylinder fillcolor="#FCE4EC"]
    Skills [label="Skills\n(5 modules)" shape=note fillcolor="#FFF9C4"]

    subgraph cluster_discovery {
        label="Discovery Agent Flow"
        style=filled fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]

        Prescan    [label="discovery-prescan\nScoping"]
        CodeTracer [label="discovery-code-tracer\nHOW"]
        BehObs     [label="discovery-behavior-observer\nWHAT [deep]"]
        IntMapper  [label="discovery-integration-mapper\nWHERE/WHY"]
        Synthesizer [label="discovery-synthesizer\nConsensus\n(×1-3 iterations)"]
    }

    subgraph cluster_general {
        label="General DOT Agents"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]
        DotAuthor [label="dot-author"]
        Reviewer  [label="diagram-reviewer"]
    }

    // Recipe dispatches
    Recipe -> Prescan [label="Stage 1:\ntopic list"]
    Recipe -> CodeTracer [label="Stage 2:\nper topic"]
    Recipe -> BehObs [label="Stage 2:\ndeep only"]
    Recipe -> IntMapper [label="Stage 2:\nper topic"]
    Recipe -> Synthesizer [label="Stage 3:\nper topic\n(retry loop)"]

    // File-system coordination
    CodeTracer -> FS [label="writes\nagents/code-tracer/" style=dashed]
    BehObs     -> FS [label="writes\nagents/behavior-observer/" style=dashed]
    IntMapper  -> FS [label="writes\nagents/integration-mapper/" style=dashed]
    FS -> Synthesizer [label="reads all\nagents/*" style=dashed]
    Synthesizer -> FS [label="writes\nmodule diagram.dot" style=dashed]

    // Skills (loaded at runtime)
    Skills -> CodeTracer [label="knowledge" style=dashed color="#888"]
    Skills -> Synthesizer [label="knowledge" style=dashed color="#888"]
    Skills -> DotAuthor [label="knowledge" style=dashed color="#888"]

    // General agents (ad-hoc, not in pipeline)
    Recipe -> DotAuthor [label="ad-hoc\ntasks" style=dashed]
    Recipe -> Reviewer [label="ad-hoc\nreviews" style=dashed]
}
