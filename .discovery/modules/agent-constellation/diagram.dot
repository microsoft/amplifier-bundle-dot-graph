digraph agent_constellation_consensus {
    label="Agent Constellation — Consensus Diagram"
    labelloc=t
    rankdir=LR
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    Recipe [label="Recipe Engine\n(orchestrator)" shape=ellipse fillcolor="#C8E6C9"]

    subgraph cluster_general {
        label="General DOT Agents (ad-hoc use)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]
        DotAuthor  [label="dot-author\nCreates DOT diagrams\nfrom description"]
        DiagReview [label="diagram-reviewer\nReviews for quality\nand correctness"]
    }

    subgraph cluster_discovery_pipeline {
        label="Discovery Pipeline Agents (triplicate investigation)"
        style=filled fillcolor="#E8F5E9"

        subgraph cluster_scope {
            label="Stage 1 — Scoping"
            style=filled fillcolor="#C8E6C9"
            node [fillcolor="#A5D6A7"]
            Prescan [label="discovery-prescan\nTopic selector\nJSON → 3-5 topics"]
        }

        subgraph cluster_investigate_agents {
            label="Stage 2 — Triplicate Investigation"
            style=filled fillcolor="#DCEDC8"
            node [fillcolor="#C5E1A5"]
            CodeTracer [label="discovery-code-tracer\nHOW: code paths\nLSP+filesystem\n[standard+deep]"]
            BehObs     [label="discovery-behavior-observer\nWHAT: patterns\n10+ instances\n[deep only]"]
            IntMapper  [label="discovery-integration-mapper\nWHERE/WHY: boundaries\n[standard+deep]"]
        }

        subgraph cluster_synth_agent {
            label="Stage 3 — Synthesis"
            style=filled fillcolor="#F3E5F5"
            node [fillcolor="#E1BEE7"]
            Synth [label="discovery-synthesizer\nConsensus builder\nNo fiat reconciliation\n×1-3 iterations"]
        }
    }

    FS     [label="File System\n(handoff medium)" shape=cylinder fillcolor="#FCE4EC"]
    Skills [label="5 Skills\n(shared knowledge)" shape=note fillcolor="#FFF9C4"]

    // Pipeline flow
    Recipe -> Prescan [label="Stage 1"]
    Recipe -> CodeTracer [label="Stage 2"]
    Recipe -> BehObs [label="Stage 2\n[deep only]" style=dashed]
    Recipe -> IntMapper [label="Stage 2"]
    Recipe -> Synth [label="Stage 3\n(quality loop)"]

    // File-system handoff (the ONLY cross-agent coordination mechanism)
    CodeTracer -> FS [label="writes" style=dashed]
    BehObs     -> FS [label="writes" style=dashed]
    IntMapper  -> FS [label="writes" style=dashed]
    FS -> Synth [label="reads all" style=dashed]
    Synth -> FS [label="writes consensus" style=dashed]

    // Skills (loaded at runtime)
    Skills -> CodeTracer  [style=dashed color="#888888"]
    Skills -> Synth       [style=dashed color="#888888"]
    Skills -> DotAuthor   [style=dashed color="#888888"]

    // Ad-hoc agents (not in pipeline)
    Recipe -> DotAuthor  [style=dashed label="ad-hoc"]
    Recipe -> DiagReview [style=dashed label="ad-hoc"]

    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.5]
        L1 [label="General agent" fillcolor="#BBDEFB"]
        L2 [label="Discovery agent" fillcolor="#C8E6C9"]
        L3 [label="File handoff" shape=cylinder fillcolor="#FCE4EC"]
        L4 [label="Knowledge" shape=note fillcolor="#FFF9C4"]
        L1 -> L2 [style=invis]
        L2 -> L3 [style=invis]
        L3 -> L4 [style=invis]
    }
}
