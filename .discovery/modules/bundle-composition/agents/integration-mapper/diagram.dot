digraph BundleCompositionIntegration {
  rankdir=TB;
  fontname="Helvetica";
  fontsize=12;
  label="Bundle Composition Integration Map\nAmplifier Foundation";
  labelloc=t;
  compound=true;
  nodesep=0.6;
  ranksep=0.8;
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=8];

  // Legend
  subgraph cluster_legend {
    label="Legend";
    style=dashed;
    color=gray60;
    fontcolor=gray40;
    fontsize=9;
    node [fontsize=8, height=0.3, margin="0.05,0.02"];
    leg_core [label="Core Mechanism", shape=box, style=filled, fillcolor="#E8D5B7"];
    leg_boundary [label="Boundary Artifact", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
    leg_subsystem [label="Adjacent Subsystem", shape=component, style=filled, fillcolor="#D5E8B7"];
    leg_kernel [label="Kernel Layer", shape=box, style="filled,bold", fillcolor="#E8B7B7"];
    leg_core -> leg_boundary [label="data flow", style=solid, color=gray50];
    leg_boundary -> leg_subsystem [label="boundary cross", style=dashed, color=gray50];
    leg_subsystem -> leg_kernel [label="emergent effect", style=dotted, color=red, fontcolor=red];
  }

  // === CORE: Bundle Composition ===
  subgraph cluster_composition {
    label="Bundle Composition (Core)";
    style=filled;
    fillcolor="#FFF8E8";
    color="#C4A06A";

    bundle_dataclass [label="Bundle\nDataclass", shape=box, style=filled, fillcolor="#E8D5B7"];
    compose_method [label="Bundle.compose()", shape=box, style=filled, fillcolor="#E8D5B7"];
    from_dict [label="Bundle.from_dict()", shape=box, style=filled, fillcolor="#E8D5B7"];
    prepare [label="Bundle.prepare()", shape=box, style=filled, fillcolor="#E8D5B7"];
    to_mount_plan [label="to_mount_plan()", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
    prepared_bundle [label="PreparedBundle", shape=box, style=filled, fillcolor="#E8D5B7"];
  }

  // === Source Resolution ===
  subgraph cluster_source {
    label="Source Resolution";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    source_resolver [label="SimpleSourceResolver", shape=component, style=filled, fillcolor="#D5E8B7"];
    git_handler [label="GitSourceHandler", shape=component, style=filled, fillcolor="#D5E8B7"];
    file_handler [label="FileSourceHandler", shape=component, style=filled, fillcolor="#D5E8B7"];
    resolved_source [label="ResolvedSource\n{active_path, source_root}", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
  }

  // === Registry ===
  subgraph cluster_registry {
    label="Bundle Registry";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    registry [label="BundleRegistry", shape=component, style=filled, fillcolor="#D5E8B7"];
    registry_state [label="BundleState\n{uri, name, includes,\nincluded_by, is_root}", shape=note, style=filled, fillcolor="#FFFFF0"];
    compose_includes [label="_compose_includes()", shape=box, style=filled, fillcolor="#E8D5B7"];
    load_single [label="_load_single()", shape=box, style=filled, fillcolor="#E8D5B7"];
    registry_json [label="registry.json", shape=cylinder, style=filled, fillcolor="#E0E0E0"];

    registry -> registry_state [dir=both];
    registry -> registry_json [label="persist"];
    load_single -> compose_includes [label="if includes"];
  }

  // === Deep Merge ===
  subgraph cluster_merge {
    label="Deep Merge System";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    deep_merge [label="deep_merge()\ndict recursive merge", shape=component, style=filled, fillcolor="#D5E8B7"];
    merge_module_lists [label="merge_module_lists()\nby module ID", shape=component, style=filled, fillcolor="#D5E8B7"];
  }

  // === @Mention Resolution ===
  subgraph cluster_mentions {
    label="@Mention Resolution";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    mention_resolver [label="BaseMentionResolver", shape=component, style=filled, fillcolor="#D5E8B7"];
    deduplicator [label="ContentDeduplicator", shape=component, style=filled, fillcolor="#D5E8B7"];
    system_prompt_factory [label="System Prompt\nFactory (dynamic)", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
    source_base_paths [label="source_base_paths\n{namespace -> Path}", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
  }

  // === Module Activation ===
  subgraph cluster_activation {
    label="Module Activation";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    activator [label="ModuleActivator", shape=component, style=filled, fillcolor="#D5E8B7"];
    bundle_module_resolver [label="BundleModuleResolver\n(sync + async lazy)", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
    install_state [label="InstallStateManager", shape=component, style=filled, fillcolor="#D5E8B7"];
    sys_path [label="sys.path\n(global mutation)", shape=parallelogram, style=filled, fillcolor="#FFE0E0"];
  }

  // === Kernel Session ===
  subgraph cluster_kernel {
    label="Kernel (amplifier-core)";
    style="filled,bold";
    fillcolor="#FFF0F0";
    color="#C46A6A";

    session [label="AmplifierSession", shape=box, style="filled,bold", fillcolor="#E8B7B7"];
    coordinator [label="Coordinator\n(capabilities, hooks)", shape=box, style="filled,bold", fillcolor="#E8B7B7"];
    mount_plan_input [label="Mount Plan\n(plain dict)", shape=hexagon, style=filled, fillcolor="#B7D5E8"];
  }

  // === Agent Spawning ===
  subgraph cluster_spawn {
    label="Agent Spawning";
    style=filled;
    fillcolor="#F0F8E8";
    color="#8AB06A";

    spawn_method [label="PreparedBundle.spawn()", shape=box, style=filled, fillcolor="#E8D5B7"];
    agent_metadata [label="_load_agent_file_metadata()\n(.md frontmatter)", shape=component, style=filled, fillcolor="#D5E8B7"];
    provider_prefs [label="ProviderPreference\n(glob patterns)", shape=component, style=filled, fillcolor="#D5E8B7"];
    child_session [label="Child Session\n(composed)", shape=box, style="filled,bold", fillcolor="#E8B7B7"];
  }

  // ===== EDGES: Boundary Crossings =====

  // Registry -> Source Resolution
  load_single -> source_resolver [label="URI string", color="#2E7D32", fontcolor="#2E7D32"];
  source_resolver -> git_handler [style=dashed, color=gray50];
  source_resolver -> file_handler [style=dashed, color=gray50];
  source_resolver -> resolved_source [label="local path"];

  // Registry -> Composition
  load_single -> from_dict [label="parsed YAML\n+ base_path", color="#2E7D32"];
  compose_includes -> compose_method [label="chain of\nincluded bundles", color="#2E7D32", fontcolor="#2E7D32"];

  // Composition -> Deep Merge
  compose_method -> deep_merge [label="session, spawn\ndicts", color="#1565C0", fontcolor="#1565C0"];
  compose_method -> merge_module_lists [label="providers,\ntools, hooks", color="#1565C0", fontcolor="#1565C0"];

  // Composition -> Mount Plan -> Kernel
  bundle_dataclass -> to_mount_plan [label="compile"];
  to_mount_plan -> mount_plan_input [label="plain dict\n(sole bridge)", color="#C62828", fontcolor="#C62828", penwidth=2];
  mount_plan_input -> session [label="config", color="#C62828"];

  // Composition -> Module Activation
  prepare -> activator [label="module specs\n{module, source}", color="#6A1B9A", fontcolor="#6A1B9A"];
  activator -> source_resolver [label="module URI", style=dashed, color=gray50];
  activator -> bundle_module_resolver [label="activated paths"];
  activator -> install_state [label="fingerprint"];
  activator -> sys_path [label="add paths", style=dotted, color=red, fontcolor=red];

  // PreparedBundle -> Session Creation
  prepared_bundle -> session [label="create_session()", color="#C62828", fontcolor="#C62828"];
  prepared_bundle -> coordinator [label="register capabilities\n(resolver, working_dir,\nmention_resolver)", color="#C62828", fontcolor="#C62828"];
  bundle_module_resolver -> coordinator [label="mount as\nmodule-source-resolver", color="#C62828"];

  // Composition -> @Mention System
  compose_method -> source_base_paths [label="populate\nnamespace->Path", color="#E65100", fontcolor="#E65100"];
  source_base_paths -> mention_resolver [label="namespace\nlookup", color="#E65100"];
  prepared_bundle -> system_prompt_factory [label="create factory\n(re-reads each call)", color="#E65100"];
  system_prompt_factory -> deduplicator [label="deduplicate"];
  system_prompt_factory -> coordinator [label="register on\ncontext manager", color="#C62828", style=dashed];

  // Agent Spawning
  prepared_bundle -> spawn_method;
  spawn_method -> compose_method [label="re-compose\nparent + child", color="#2E7D32", fontcolor="#2E7D32", style=dashed];
  spawn_method -> provider_prefs [label="model glob\nresolution"];
  spawn_method -> child_session [label="execute + capture\nvia orchestrator:complete hook"];
  agent_metadata -> bundle_dataclass [label="agent .md ->\nagent config", style=dashed, color=gray50];

  // Emergent: sys.path inheritance
  sys_path -> child_session [label="bundle_package_paths\ninherited", style=dotted, color=red, fontcolor=red];
}
