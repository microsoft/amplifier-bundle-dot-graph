digraph pipeline_integration_boundaries {
    label="Discovery Pipeline — Integration Boundaries"
    labelloc=t
    rankdir=TB
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10]

    // Recipe engine
    RecipeEngine [label="Recipe Framework\nEngine" shape=ellipse fillcolor="#C8E6C9"]
    Human [label="Human Reviewer\n(approval gate)" shape=ellipse fillcolor="#FFF9C4"]

    subgraph cluster_outer {
        label="discovery-pipeline.yaml (outer)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]
        S1 [label="Stage 1: Scan"]
        AG [label="Approval Gate" shape=diamond fillcolor="#FFF9C4"]
        S2 [label="Stage 2: Investigate\n(foreach topics)"]
        S3 [label="Stage 3: Synthesize\n(foreach topics)"]
        S1 -> AG -> S2 -> S3
    }

    subgraph cluster_investigate {
        label="discovery-investigate-topic.yaml (sub)"
        style=filled fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]
        CodeT [label="code-tracer (agent)"]
        IntM  [label="integration-mapper (agent)"]
    }

    subgraph cluster_synthesize {
        label="discovery-synthesize-module.yaml (sub)"
        style=filled fillcolor="#F3E5F5"
        node [fillcolor="#E1BEE7"]
        SynthAgent [label="synthesizer (agent)\n×1-3 iterations"]
        ValidBash  [label="validate (bash)"]
    }

    Git [label="Git Repo\n(commit history)" shape=cylinder fillcolor="#FCE4EC"]
    FS  [label="File System\n(.discovery/)" shape=cylinder fillcolor="#FCE4EC"]

    // Engine coordinates
    RecipeEngine -> S1 [label="drives"]
    Human -> AG [label="approves/denies"]

    // Sub-recipe delegation
    S2 -> CodeT [lhead=cluster_investigate label="foreach topic\n(separate session)"]
    S3 -> SynthAgent [lhead=cluster_synthesize label="foreach topic\n(separate session)"]

    // I/O boundaries
    S1 -> Git [label="reads commit hash" style=dashed]
    CodeT -> FS [label="writes agent artifacts" style=dashed]
    SynthAgent -> FS [label="reads+writes diagram.dot" style=dashed]
    S3 -> FS [label="reads+assembles" style=dashed]

    // Context threading (Jinja2)
    S1 -> S3 [label="{{change_result.*}}\n(cross-stage context)" style=dashed color="#E57373"]

    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.5]
        L1 [label="Process" shape=ellipse fillcolor="#C8E6C9"]
        L2 [label="Stage/Step" fillcolor="#BBDEFB"]
        L3 [label="Storage" shape=cylinder fillcolor="#FCE4EC"]
        L1 -> L2 [style=invis]
        L2 -> L3 [style=invis]
    }
}
