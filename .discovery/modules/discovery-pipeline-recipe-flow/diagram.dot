digraph discovery_pipeline_consensus {
    label="Discovery Pipeline Recipe Flow — Consensus Diagram"
    labelloc=t
    rankdir=TB
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    Human [label="Human Reviewer" shape=ellipse fillcolor="#C8E6C9"]
    Git   [label="Git Repository" shape=cylinder fillcolor="#FCE4EC"]
    FS    [label=".discovery/\nOutput Dir" shape=cylinder fillcolor="#FCE4EC"]

    subgraph cluster_outer {
        label="discovery-pipeline.yaml (outer orchestrator)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]

        subgraph cluster_s1 {
            label="Stage 1: Scan"
            style=filled fillcolor="#BBDEFB"
            node [fillcolor="#90CAF9"]
            CD  [label="change-detect\nCommit diff → tier:\nfull|incremental|skip"]
            SS  [label="structural-scan\nprescan_repo() → inventory\n[tier != skip]"]
            TS  [label="topic-select\ndiscovery-prescan agent\n3-5 topics [standard]"]
            AG  [label="APPROVAL GATE\nHuman reviews topics" shape=diamond fillcolor="#FFF9C4"]
            CD -> SS -> TS -> AG
        }

        subgraph cluster_s2 {
            label="Stage 2: Investigate"
            style=filled fillcolor="#C8E6C9"
            node [fillcolor="#A5D6A7"]
            PT  [label="prepare-topics\nCreate dir structure"]
            IT  [label="investigate-topics\nforeach topic\n→ sub-recipe" shape=component]
            PT -> IT
        }

        subgraph cluster_s3 {
            label="Stage 3: Synthesize"
            style=filled fillcolor="#FFE0B2"
            node [fillcolor="#FFCC80"]
            RM  [label="reconcile-modules\nforeach topic\n→ sub-recipe" shape=component]
            AS  [label="assemble\nassemble_hierarchy()\n→ overview.dot"]
            FV  [label="final-validate\npydot check all .dot"]
            UM  [label="update-metadata\nlast-run.json"]
            RM -> AS -> FV -> UM
        }

        AG -> PT [label="APPROVED"]
        IT -> RM [lhead=cluster_s3]
    }

    subgraph cluster_investigate_sub {
        label="discovery-investigate-topic.yaml (per topic)"
        style=filled fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]
        CT   [label="code-tracer\nHOW: code paths\n[standard+deep]"]
        BO   [label="behavior-observer\nWHAT: patterns\n[deep only]"]
        IM   [label="integration-mapper\nWHERE/WHY: boundaries\n[standard+deep]"]
    }

    subgraph cluster_synthesize_sub {
        label="discovery-synthesize-module.yaml (per topic)"
        style=filled fillcolor="#F3E5F5"
        node [fillcolor="#E1BEE7"]
        QG  [label="quality-gate\nwhile loop (max 3×)" shape=component]
        SY  [label="synthesize\nconsensus diagram"]
        VA  [label="validate\npydot check"]
        CQ  [label="check-quality\npass/retry?"]
        QG -> SY -> VA -> CQ
        CQ -> QG [label="retry if\nnot valid" style=dashed color="#E57373"]
    }

    // Sub-recipe delegation
    IT -> CT [lhead=cluster_investigate_sub label="foreach topic"]
    RM -> QG [lhead=cluster_synthesize_sub label="foreach topic"]

    // I/O
    CD -> Git [label="reads commits" style=dashed]
    CT -> FS  [label="writes agent artifacts" style=dashed]
    SY -> FS  [label="reads+writes diagram.dot" style=dashed]
    AS -> FS  [label="writes overview.dot" style=dashed]
    UM -> FS  [label="writes last-run.json" style=dashed]
    Human -> AG [label="approves"]
}
