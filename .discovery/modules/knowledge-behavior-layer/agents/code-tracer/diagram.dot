digraph knowledge_behavior_layer {
    label="Knowledge and Behavior Layer — Composition"
    labelloc=t
    rankdir=TB
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    BundleMD [label="bundle.md\n(dot-graph v0.2.0)\nEntry point" shape=ellipse fillcolor="#C8E6C9"]

    subgraph cluster_behaviors {
        label="Behaviors (YAML composition)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]

        DotGraph     [label="dot-graph.yaml\n(composite only)"]
        DotCore      [label="dot-core.yaml\n+ tool-dot-graph\n+ tool-skills (5 skills)\n+ dot-author\n+ diagram-reviewer"]
        DotDiscovery [label="dot-discovery.yaml\n+ 5 discovery agents\n+ discovery-awareness.md"]

        DotGraph -> DotCore [label="includes"]
        DotGraph -> DotDiscovery [label="includes"]
        DotDiscovery -> DotCore [label="includes"]
    }

    subgraph cluster_skills {
        label="Skills (5 directories)"
        style=filled fillcolor="#F3E5F5"
        node [fillcolor="#E1BEE7"]
        DotSyntax    [label="dot-syntax\nLanguage reference"]
        DotPatterns  [label="dot-patterns\nTemplate library"]
        DotQuality   [label="dot-quality\nQuality standards"]
        DotIntel     [label="dot-graph-intelligence\nAnalysis operations"]
        DotAnalysis  [label="dot-as-analysis\nAnalysis methodology"]
    }

    subgraph cluster_tools {
        label="Tools"
        style=filled fillcolor="#E8F5E9"
        node [fillcolor="#C8E6C9"]
        ToolDotGraph [label="tool-dot-graph\n6 operations\n(validate/render/setup\nanalyze/prescan/assemble)"]
        ToolSkills   [label="tool-skills\n(external module)\nserves skill content"]
    }

    subgraph cluster_context {
        label="Context Files"
        style=filled fillcolor="#FFF9C4"
        node [fillcolor="#FFF59D" shape=note]
        DotAwareness     [label="dot-awareness.md\n(bundle.md inline)"]
        DiscoveryAware   [label="discovery-awareness.md\n(via dot-discovery)"]
    }

    // Bundle → behaviors
    BundleMD -> DotGraph [label="includes behavior"]

    // Core provides tools + skills
    DotCore -> ToolDotGraph [label="mounts tool"]
    DotCore -> ToolSkills [label="mounts tool\n(loads 5 skills)"]
    ToolSkills -> DotSyntax [label="serves" style=dashed]
    ToolSkills -> DotPatterns [label="serves" style=dashed]
    ToolSkills -> DotQuality [label="serves" style=dashed]
    ToolSkills -> DotIntel [label="serves" style=dashed]
    ToolSkills -> DotAnalysis [label="serves" style=dashed]

    // Context injection
    BundleMD -> DotAwareness [label="inline" style=dashed]
    DotDiscovery -> DiscoveryAware [label="injects" style=dashed]
}
