digraph knowledge_behavior_consensus {
    label="Knowledge and Behavior Layer — Consensus Diagram"
    labelloc=t
    rankdir=TB
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    Consumer [label="Any Amplifier Session\n(bundle consumer)" shape=ellipse fillcolor="#C8E6C9"]

    subgraph cluster_bundle {
        label="amplifier-bundle-dot-graph  (v0.2.0)"
        style=filled fillcolor="#E3F2FD"

        BundleMD [label="bundle.md\n(entry point)\nalways includes:\ndot-awareness.md" fillcolor="#BBDEFB"]

        subgraph cluster_behaviors {
            label="Behavior Composition Chain"
            style=filled fillcolor="#E8F5E9"
            node [fillcolor="#C8E6C9"]
            DotGraph  [label="dot-graph.yaml\n(v0.2.0)\nPure composite:\nincludes core+discovery"]
            DotCore   [label="dot-core.yaml\n(v0.2.0)\nProvides:\ntool-dot-graph\ntool-skills (5 skills)\ndot-author\ndiagram-reviewer"]
            DotDisc   [label="dot-discovery.yaml\n(v0.1.0)\nProvides:\n5 discovery agents\ndiscovery-awareness.md\n(includes dot-core)"]
            DotGraph -> DotCore [label="includes"]
            DotGraph -> DotDisc [label="includes"]
            DotDisc  -> DotCore [label="includes\n(transitive)"]
        }

        subgraph cluster_skills {
            label="5 Skills (served via tool-skills)"
            style=filled fillcolor="#FFF3E0"
            node [fillcolor="#FFE0B2" shape=note]
            S1 [label="dot-syntax\nLanguage reference"]
            S2 [label="dot-patterns\nTemplate library"]
            S3 [label="dot-quality\nQuality standards"]
            S4 [label="dot-graph-intelligence\nAnalysis operations"]
            S5 [label="dot-as-analysis\nAnalysis methodology"]
        }

        subgraph cluster_context {
            label="Context Files (always injected)"
            style=filled fillcolor="#F3E5F5"
            node [fillcolor="#E1BEE7" shape=note]
            C1 [label="dot-awareness.md\n(all sessions)"]
            C2 [label="discovery-awareness.md\n(discovery sessions only)"]
        }
    }

    subgraph cluster_external {
        label="External Dependencies (GitHub URLs)"
        style=filled fillcolor="#FCE4EC"
        node [fillcolor="#F8BBD9" shape=parallelogram]
        ToolDG [label="tool-dot-graph\n(this repo subdirectory)\n6 operations"]
        ToolSk [label="tool-skills\n(external repo)\nskill content server"]
    }

    // Entry
    Consumer -> BundleMD [label="includes bundle\ngets full stack"]

    // Behavior chain
    BundleMD -> DotGraph

    // Tool loading (external)
    DotCore -> ToolDG [label="loads tool\n(GitHub URL)" color="#E57373"]
    DotCore -> ToolSk [label="loads tool\n(GitHub URL)" color="#E57373"]

    // Skills served via tool-skills
    ToolSk -> S1 [style=dashed]
    ToolSk -> S2 [style=dashed]
    ToolSk -> S3 [style=dashed]
    ToolSk -> S4 [style=dashed]
    ToolSk -> S5 [style=dashed]

    // Context injection
    BundleMD -> C1 [style=dashed label="inline"]
    DotDisc  -> C2 [style=dashed]

    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.5]
        La [label="Consumer" shape=ellipse fillcolor="#C8E6C9"]
        Lb [label="Behavior" fillcolor="#C8E6C9"]
        Lc [label="External" shape=parallelogram fillcolor="#F8BBD9"]
        Ld [label="Knowledge" shape=note fillcolor="#FFE0B2"]
        La -> Lb [style=invis]
        Lb -> Lc [style=invis]
        Lc -> Ld [style=invis]
    }
}
