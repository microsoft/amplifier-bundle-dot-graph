digraph module_ecosystem {
    rankdir=TB
    compound=true
    node [fontname="Helvetica" fontsize=11]
    edge [fontname="Helvetica" fontsize=10]

    // ─────────────────────────────────────────────────────────
    // CLUSTER: App Layer (Foundation) — Bundle Preparation
    // ─────────────────────────────────────────────────────────
    subgraph cluster_app_layer {
        label="App Layer: amplifier-foundation"
        style=filled
        fillcolor="#e8f4e8"
        node [shape=box style=filled fillcolor="#c8e8c8"]

        bundle_prepare [label="Bundle.prepare()\nbundle.py:245"]
        bundle_to_mount_plan [label="Bundle.to_mount_plan()\nbundle.py:215"]
        activate_bundle_pkg [label="ModuleActivator\n.activate_bundle_package()\nactivator.py:167"]
        activate_all [label="ModuleActivator\n.activate_all()\nactivator.py:125"]
        activate_single [label="ModuleActivator\n.activate()\nactivator.py:68"]
        create_resolver [label="BundleModuleResolver\n(module_paths, activator)\nbundle.py:383"]
        prepared_bundle [label="PreparedBundle\n.create_session()\nbundle.py:1043" shape=diamond fillcolor="#a8d8a8"]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Source Resolution — Foundation Policy
    // ─────────────────────────────────────────────────────────
    subgraph cluster_source_resolution {
        label="Source Resolution (App-Layer Policy)"
        style=filled
        fillcolor="#fff8e8"
        node [shape=box style=filled fillcolor="#ffe8a8"]

        simple_resolver [label="SimpleSourceResolver\n.resolve(uri)\nresolver.py:63"]
        file_handler [label="FileSourceHandler\nfile.py"]
        git_handler [label="GitSourceHandler\n.resolve()\ngit.py:144"]
        zip_handler [label="ZipSourceHandler\nzip.py"]
        http_handler [label="HttpSourceHandler\nhttp.py"]
        git_cache [label="~/.amplifier/cache/\nbundles/<sha16>/\ngit.py:44-50" shape=cylinder fillcolor="#ffd080"]
        resolved_source [label="ResolvedSource\n(active_path, source_root)" shape=ellipse]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Kernel — Session Init
    // ─────────────────────────────────────────────────────────
    subgraph cluster_kernel_init {
        label="Kernel: Session Initialization\n_session_init.py"
        style=filled
        fillcolor="#e8e8f8"
        node [shape=box style=filled fillcolor="#c8c8f0"]

        initialize_session [label="initialize_session()\n_session_init.py:22"]
        load_orchestrator [label="Load Orchestrator\n(REQUIRED)\n_session_init.py:47-72"]
        load_context [label="Load ContextManager\n(REQUIRED)\n_session_init.py:74-99"]
        load_providers [label="Load Providers\n(non-fatal)\n_session_init.py:121"]
        load_tools [label="Load Tools\n(non-fatal)\n_session_init.py:185"]
        load_hooks [label="Load Hooks\n(non-fatal)\n_session_init.py:207"]
        session_fork_event [label="Emit session:fork\n(if child session)\n_session_init.py:229" shape=ellipse]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Kernel — Module Loader
    // ─────────────────────────────────────────────────────────
    subgraph cluster_module_loader {
        label="Kernel: ModuleLoader\nloader.py"
        style=filled
        fillcolor="#f0e8f8"
        node [shape=box style=filled fillcolor="#d8b8f0"]

        loader_load [label="ModuleLoader.load()\nloader.py:176"]
        loader_cache_check [label="Cache check\n_loaded_modules\nloader.py:202"]
        get_source_resolver [label="coordinator.get(\n'module-source-resolver')\nloader.py:221"]
        load_direct [label="_load_direct()\n(entry points + fs)\nloader.py:340"]
        resolver_async_resolve [label="resolver.async_resolve()\nor resolve()\nloader.py:237-247"]
        source_resolve_path [label="source.resolve() → Path\nloader.py:248"]
        sys_path_inject [label="sys.path.insert(0, path)\nloader.py:256"]
        polyglot_dispatch [label="Polyglot Dispatch\n_engine.resolve_module()\nloader.py:268" shape=diamond]
        validate_module [label="_validate_module()\nloader.py:292"]
        load_entry_point [label="_load_entry_point()\nimportlib.metadata\nloader.py:381"]
        load_filesystem [label="_load_filesystem()\nimportlib.import_module()\nloader.py:404"]
        mount_closure [label="mount_with_config\nclosure returned\nloader.py:313" shape=ellipse]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Polyglot Transports
    // ─────────────────────────────────────────────────────────
    subgraph cluster_polyglot {
        label="Polyglot Module Transports"
        style=filled
        fillcolor="#fce8e8"
        node [shape=box style=filled fillcolor="#f0b8b8"]

        wasm_mount [label="WASM Mount\n_engine.load_and_mount_wasm()\nloader.py:654"]
        grpc_mount [label="gRPC Mount\nloader_grpc.load_grpc_module()\nloader.py:683"]
        python_mount [label="Python Mount\nimport + mount()\nloader.py:308-330"]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Coordinator (Rust)
    // ─────────────────────────────────────────────────────────
    subgraph cluster_coordinator {
        label="Kernel: RustCoordinator\ncoordinator.rs"
        style=filled
        fillcolor="#e8f8f8"
        node [shape=box style=filled fillcolor="#b8e8e8"]

        coord_orchestrator [label="orchestrator: Mutex<Option<Arc>>\nsingle slot\ncoordinator.rs:76"]
        coord_context [label="context: Mutex<Option<Arc>>\nsingle slot\ncoordinator.rs:77"]
        coord_providers [label="providers: HashMap<String,Arc>\nnamed map\ncoordinator.rs:78"]
        coord_tools [label="tools: HashMap<String,Arc>\nnamed map\ncoordinator.rs:79"]
        coord_capabilities [label="capabilities: HashMap<String,Value>\ngeneric registry\ncoordinator.rs:86"]
        coord_hooks [label="HookRegistry\nArc shared\ncoordinator.rs:82"]
        coord_cleanup [label="cleanup_functions: Vec<CleanupFn>\ncoordinator.rs:90"]
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Module Contract (example)
    // ─────────────────────────────────────────────────────────
    subgraph cluster_module_contract {
        label="Module Contract Example: tool-dot-graph"
        style=filled
        fillcolor="#f8f0e8"
        node [shape=box style=filled fillcolor="#e8d0b0"]

        module_mount_fn [label="async mount(coordinator, config)\n__init__.py:274"]
        module_impl [label="DotGraphTool instance\n(implements Tool protocol)\n__init__.py:28"]
        module_register [label="coordinator.mount('tools', tool,\nname=tool.name)\n__init__.py:290"]
        module_return [label="return metadata dict\nor cleanup callable\n__init__.py:297"]
    }

    // ─────────────────────────────────────────────────────────
    // EDGES: App Layer → Session Init
    // ─────────────────────────────────────────────────────────
    bundle_prepare -> bundle_to_mount_plan [label="1. compile"]
    bundle_prepare -> activate_bundle_pkg [label="2. install\nbundle pkgs first"]
    bundle_prepare -> activate_all [label="3. parallel\nactivation"]
    activate_all -> activate_single [label="asyncio.gather()" style=dashed]
    activate_single -> simple_resolver [label="resolve URI"]
    activate_single -> sys_path_inject [label="adds path" style=dashed lhead=cluster_module_loader]
    bundle_prepare -> create_resolver [label="4. BundleModuleResolver"]
    bundle_prepare -> prepared_bundle [label="5. returns"]
    prepared_bundle -> initialize_session [label="mount resolver\nthen initialize()\nbundle.py:1095,1115"]

    // ─────────────────────────────────────────────────────────
    // EDGES: Source Resolution
    // ─────────────────────────────────────────────────────────
    simple_resolver -> file_handler [label="file://"]
    simple_resolver -> git_handler [label="git+https://"]
    simple_resolver -> zip_handler [label="zip+https://"]
    simple_resolver -> http_handler [label="https://"]
    git_handler -> git_cache [label="cache or clone"]
    git_handler -> resolved_source [label="returns"]
    activate_single -> resolved_source [label="active_path"]

    // ─────────────────────────────────────────────────────────
    // EDGES: Session Init → Loader
    // ─────────────────────────────────────────────────────────
    initialize_session -> load_orchestrator
    initialize_session -> load_context
    initialize_session -> load_providers
    initialize_session -> load_tools
    initialize_session -> load_hooks
    initialize_session -> session_fork_event [label="if parent_id" style=dashed]

    load_orchestrator -> loader_load [label="FATAL if fails"]
    load_context -> loader_load [label="FATAL if fails"]
    load_providers -> loader_load [label="warn if fails"]
    load_tools -> loader_load [label="warn if fails"]
    load_hooks -> loader_load [label="warn if fails"]

    // ─────────────────────────────────────────────────────────
    // EDGES: Loader internals
    // ─────────────────────────────────────────────────────────
    loader_load -> loader_cache_check [label="1. check cache"]
    loader_load -> get_source_resolver [label="2. get resolver"]
    get_source_resolver -> load_direct [label="none mounted\n(fallback)"]
    get_source_resolver -> resolver_async_resolve [label="resolver present"]
    resolver_async_resolve -> source_resolve_path
    source_resolve_path -> sys_path_inject [label="3. inject path"]
    sys_path_inject -> polyglot_dispatch [label="4. check transport"]
    polyglot_dispatch -> wasm_mount [label="transport=wasm"]
    polyglot_dispatch -> grpc_mount [label="transport=grpc"]
    polyglot_dispatch -> python_mount [label="transport=python\n(fall-through)"]
    python_mount -> validate_module
    validate_module -> load_entry_point [label="5. try entry points"]
    validate_module -> load_filesystem [label="fallback"]
    load_entry_point -> mount_closure [label="returns"]
    load_filesystem -> mount_closure [label="returns"]
    load_direct -> load_entry_point [style=dashed]
    load_direct -> load_filesystem [style=dashed]

    // ─────────────────────────────────────────────────────────
    // EDGES: Mount closure → Coordinator
    // ─────────────────────────────────────────────────────────
    mount_closure -> module_mount_fn [label="calls mount(coordinator,\nconfig)"]
    module_mount_fn -> module_impl [label="instantiate"]
    module_mount_fn -> module_register [label="register"]
    module_register -> coord_tools [label="tools"]
    module_register -> coord_providers [label="providers"]
    module_register -> coord_orchestrator [label="orchestrator"]
    module_register -> coord_context [label="context"]
    module_register -> coord_hooks [label="hooks"]
    module_mount_fn -> module_return
    module_return -> coord_cleanup [label="if cleanup fn" style=dashed]

    // ─────────────────────────────────────────────────────────
    // CLUSTER: Legend
    // ─────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        rank=sink
        node [shape=box fontsize=10]

        leg_entry [label="Entry Point" shape=diamond style=filled fillcolor="#a8d8a8"]
        leg_kernel [label="Kernel Mechanism" style=filled fillcolor="#c8c8f0"]
        leg_app [label="App-Layer Policy" style=filled fillcolor="#c8e8c8"]
        leg_source [label="Source Resolution" style=filled fillcolor="#ffe8a8"]
        leg_module [label="Module Contract" style=filled fillcolor="#e8d0b0"]
        leg_store [label="Storage / I/O" shape=cylinder style=filled fillcolor="#ffd080"]
        leg_fatal [label="FATAL if fails" shape=ellipse style=filled fillcolor="#ffb0b0"]
        leg_nonfatal [label="non-fatal (warning)" shape=ellipse style=filled fillcolor="#b0d8b0"]

        leg_entry -> leg_kernel [style=invis]
        leg_kernel -> leg_app [style=invis]
        leg_app -> leg_source [style=invis]
        leg_source -> leg_module [style=invis]
        leg_module -> leg_store [style=invis]
        leg_store -> leg_fatal [style=invis]
        leg_fatal -> leg_nonfatal [style=invis]
    }
}
