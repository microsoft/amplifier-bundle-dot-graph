digraph tool_module_architecture {
    label="Tool Module Architecture — Code Paths"
    labelloc=t
    rankdir=LR
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    // Entry points
    Coordinator [label="Amplifier\nCoordinator" shape=ellipse fillcolor="#C8E6C9"]
    Mount [label="mount(coordinator)" shape=box fillcolor="#E8F0FE"]

    // Router
    subgraph cluster_router {
        label="DotGraphTool (__init__.py)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]
        Execute [label="execute(input_data)\n[operation dispatch]" shape=component]
    }

    // Operations
    subgraph cluster_ops {
        label="Operation Modules"
        style=filled fillcolor="#F3E5F5"
        node [fillcolor="#E1BEE7"]
        Validate [label="validate.py\nvalidate_dot()\n3-layer checks"]
        Render   [label="render.py\nrender_dot()\ngraphviz CLI"]
        Setup    [label="setup_helper.py\ncheck_environment()"]
        Analyze  [label="analyze.py\nanalyze_dot()\n8 operations"]
        Prescan  [label="prescan.py\nprescan_repo()\nos.walk walker"]
        Assemble [label="assemble.py\nassemble_hierarchy()\npydot builder"]
    }

    // External deps
    Graphviz [label="graphviz CLI" shape=parallelogram fillcolor="#FFF9C4"]
    Pydot    [label="pydot library" shape=parallelogram fillcolor="#FFF9C4"]
    Networkx [label="networkx library" shape=parallelogram fillcolor="#FFF9C4"]
    FS       [label="File System" shape=cylinder fillcolor="#FCE4EC"]

    // Connections
    Coordinator -> Mount [label="load module"]
    Mount -> Execute [label="registers tool\nas 'dot_graph'"]

    Execute -> Validate [label="validate"]
    Execute -> Render   [label="render"]
    Execute -> Setup    [label="setup"]
    Execute -> Analyze  [label="analyze"]
    Execute -> Prescan  [label="prescan"]
    Execute -> Assemble [label="assemble"]

    Render  -> Graphviz [label="shell out"]
    Setup   -> Graphviz [label="check"]
    Setup   -> Pydot    [label="check"]
    Analyze -> Networkx [label="import"]
    Validate -> Pydot   [label="import"]
    Assemble -> Pydot   [label="import"]
    Prescan -> FS       [label="os.walk"]
    Assemble -> FS      [label="write .dot"]

    // Legend
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.4]
        L_entry  [label="Entry Point" shape=ellipse fillcolor="#C8E6C9"]
        L_router [label="Router"      fillcolor="#BBDEFB"]
        L_mod    [label="Module"      fillcolor="#E1BEE7"]
        L_ext    [label="External"    shape=parallelogram fillcolor="#FFF9C4"]
        L_entry -> L_router [style=invis]
        L_router -> L_mod   [style=invis]
        L_mod   -> L_ext    [style=invis]
    }
}
