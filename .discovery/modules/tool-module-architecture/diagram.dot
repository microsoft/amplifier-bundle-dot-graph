digraph tool_module_architecture_consensus {
    label="Tool Module Architecture — Consensus Diagram"
    labelloc=t
    rankdir=LR
    compound=true
    node [fontname="Helvetica" style="rounded,filled"]
    edge [fontname="Helvetica" fontsize=10 color="#666666"]

    // Amplifier integration boundary
    Coordinator [label="Amplifier\nCoordinator" shape=ellipse fillcolor="#C8E6C9"]
    Discovery [label="Discovery Pipeline\n(YAML recipes)" shape=note fillcolor="#FFF9C4"]

    subgraph cluster_module {
        label="amplifier_module_tool_dot_graph  (v0.4.0)"
        style=filled fillcolor="#E3F2FD"
        node [fillcolor="#BBDEFB"]

        Mount   [label="mount(coordinator)\nregisters as 'dot_graph'"]
        Execute [label="execute(input_data)\noperation dispatcher\n[if/elif chain]" shape=component]

        subgraph cluster_operations {
            label="6 Operations"
            style=filled fillcolor="#E8EAF6"
            node [fillcolor="#C5CAE9"]
            Validate [label="validate\nvalidate_dot()\n3-layer syntax check"]
            Render   [label="render\nrender_dot()\ngraphviz CLI wrapper"]
            Setup    [label="setup\ncheck_environment()\nprobe dependencies"]
            Analyze  [label="analyze\nanalyze_dot()\n8 analysis types"]
            Prescan  [label="prescan\nprescan_repo()\nos.walk inventory"]
            Assemble [label="assemble\nassemble_hierarchy()\nDOT file merger"]
        }

        Mount -> Execute [label="registered"]
        Execute -> Validate
        Execute -> Render
        Execute -> Setup
        Execute -> Analyze
        Execute -> Prescan
        Execute -> Assemble
    }

    // External dependencies (identified by integration-mapper)
    subgraph cluster_deps {
        label="External Dependencies"
        style=filled fillcolor="#FFF3E0"
        node [fillcolor="#FFE0B2"]
        Pydot    [label="pydot\n(module-level import\nin assemble.py)" shape=parallelogram]
        Networkx [label="networkx" shape=parallelogram]
        GvCLI    [label="graphviz CLI" shape=parallelogram]
        FS       [label="File System" shape=cylinder fillcolor="#FCE4EC"]
    }

    // Amplifier integration
    Coordinator -> Mount [label="module load\n(async)"]

    // Discovery pipeline integration (with bugs noted)
    Discovery -> Prescan [label="prescan_repo()\n✓ FIXED" color="#43A047"]
    Discovery -> Assemble [label="assemble_hierarchy()\n✓ FIXED" color="#43A047"]

    // Dependency usage
    Validate -> Pydot
    Assemble -> Pydot [label="module-level import\n⚠ fails if missing"]
    Analyze  -> Networkx
    Render   -> GvCLI
    Setup    -> GvCLI [label="probe"]
    Setup    -> Pydot [label="probe"]
    Prescan  -> FS [label="os.walk (read-only)"]
    Assemble -> FS [label="writes .dot files"]

    // Legend
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor="#F5F5F5"
        node [width=1.5]
        La [label="Entry point" shape=ellipse fillcolor="#C8E6C9"]
        Lb [label="Module internals" fillcolor="#BBDEFB"]
        Lc [label="Operations" fillcolor="#C5CAE9"]
        Ld [label="External dep" shape=parallelogram fillcolor="#FFE0B2"]
        La -> Lb [style=invis]
        Lb -> Lc [style=invis]
        Lc -> Ld [style=invis]
    }
}
