digraph ecosystem_governance {
  graph [rankdir=TB, fontname="Helvetica", fontsize=14, compound=true,
    label="Ecosystem Governance & Awareness Hierarchy\nSynthesis from 4 Investigation Perspectives",
    labelloc=t, pad=0.5, nodesep=0.6, ranksep=0.8]
  node [fontname="Helvetica", fontsize=10, style=filled]
  edge [fontname="Helvetica", fontsize=8]

  // ===================================================================
  // CLUSTER: Governance Rules Layer (docs/)
  // ===================================================================
  subgraph cluster_governance_rules {
    label="Governance Rules (docs/)\n[C-05: Zero mechanical enforcement]"
    style=filled
    fillcolor="#E3F2FD"
    color="#1565C0"

    repo_rules [label="REPOSITORY_RULES.md\n(585 lines, 18KB)\nGolden Rule +\nAwareness Hierarchy" shape=note fillcolor="#BBDEFB"]
    modules_md [label="MODULES.md\n(25KB, 323 lines)\nEcosystem Registry\n[C-06: SPOF]" shape=note fillcolor="#FFCDD2"]
    broken_refs [label="13+ Missing Refs\n(silent content gaps)" shape=note fillcolor="#FFCDD2" style="filled,dashed"]
  }

  // ===================================================================
  // CLUSTER: Context Injection Triad (context/)
  // ===================================================================
  subgraph cluster_context_triad {
    label="Context Injection Triad (context/)\n[C-10: ~6.5KB balanced files]"
    style=filled
    fillcolor="#FFF3E0"
    color="#E65100"

    ctx_overview [label="ecosystem-overview.md\n(6.6KB)\nArchitectural orientation" shape=note fillcolor="#FFE0B2"]
    ctx_hygiene [label="development-hygiene.md\n(6.3KB)\nOperational safety" shape=note fillcolor="#FFE0B2"]
    ctx_recipes [label="recipes-usage.md\n(6.7KB)\nWorkflow execution\n[D-04: soft ref?]" shape=note fillcolor="#FFE0B2"]
  }

  // ===================================================================
  // CLUSTER: Knowledge Architecture (agents/, behaviors/)
  // ===================================================================
  subgraph cluster_knowledge_arch {
    label="Knowledge Architecture\n[C-07: Hub-and-Spoke, C-08: 5-Tier Hierarchy]"
    style=filled
    fillcolor="#E8F5E9"
    color="#2E7D32"

    expert_agent [label="amplifier-expert.md\n(15KB, sole agent)\nHub / Ecosystem Router\nRESEARCH | GUIDE | VALIDATE" shape=doubleoctagon fillcolor="#C8E6C9"]
    bhv_expert [label="amplifier-expert-behavior\n(agent + context)\nActive injection" shape=note fillcolor="#BBDEFB"]
    bhv_dev [label="amplifier-dev-behavior\n(context-only)\nPassive injection" shape=note fillcolor="#BBDEFB"]
    spoke_agents [label="3 Spoke Experts\ncore-expert\nfoundation-expert\nrecipe-author" shape=octagon fillcolor="#C8E6C9"]
  }

  // ===================================================================
  // CLUSTER: 5-Tier Knowledge Hierarchy
  // ===================================================================
  subgraph cluster_tiers {
    label="5-Tier @-mention Hierarchy\n[C-08: no runtime priority enforcement]"
    style=filled
    fillcolor="#F3E5F5"
    color="#AB47BC"

    tier0 [label="T0: @core:docs/\nKernel internals" shape=component fillcolor="#E1BEE7"]
    tier1 [label="T1: @amplifier:docs/\nEntry-point docs" shape=component fillcolor="#E1BEE7"]
    tier2 [label="T2: @foundation:docs/\nFoundation library" shape=component fillcolor="#E1BEE7"]
    tier3 [label="T3: @foundation:context/\nCore philosophy" shape=component fillcolor="#E1BEE7"]
    tier4 [label="T4: @recipes:docs/\nWorkflow recipes" shape=component fillcolor="#E1BEE7"]
  }

  // ===================================================================
  // CLUSTER: Module Loading Infrastructure (amplifier-core kernel)
  // ===================================================================
  subgraph cluster_module_infra {
    label="Module Loading Infrastructure (amplifier-core)\n[C-02: Strict kernel/policy separation]"
    style=filled
    fillcolor="#E8E8F8"
    color="#5C6BC0"

    session_init [label="initialize_session()\n[C-09: Fatal/Non-fatal\nasymmetry]" shape=box fillcolor="#C5CAE9"]
    module_loader [label="ModuleLoader.load()\nCache + resolve +\nvalidate + mount" shape=box fillcolor="#C5CAE9"]
    coordinator [label="RustCoordinator\norchestrator | context |\nproviders | tools | hooks" shape=box3d fillcolor="#C5CAE9"]
    polyglot [label="Polyglot Dispatch\nPython | WASM | gRPC" shape=diamond fillcolor="#C5CAE9"]
  }

  // ===================================================================
  // CLUSTER: Foundation Policy Layer
  // ===================================================================
  subgraph cluster_foundation {
    label="Foundation Policy Layer\n(amplifier-foundation)"
    style=filled
    fillcolor="#E8F8E8"
    color="#43A047"

    bundle_prepare [label="Bundle.prepare()\nParallel activation\nModule resolution" shape=box fillcolor="#C8E6C9"]
    source_resolver [label="SimpleSourceResolver\nFile | Git | Zip | HTTP" shape=box fillcolor="#C8E6C9"]
    bundle_resolver [label="BundleModuleResolver\nLazy agent activation" shape=box fillcolor="#C8E6C9"]
  }

  // ===================================================================
  // SHARED PROTOCOLS (boundary interfaces)
  // ===================================================================
  at_mention [label="@-mention Protocol\n[C-03: Sole delivery mechanism]\nparse_mentions() +\nBaseMentionResolver +\nContentDeduplicator" shape=hexagon fillcolor="#CE93D8"]

  prompt_factory [label="System Prompt Factory\nPer-request assembly\n(no caching)" shape=hexagon fillcolor="#CE93D8"]

  // ===================================================================
  // CLUSTER: Enforcement Mechanisms
  // ===================================================================
  subgraph cluster_enforcement {
    label="Enforcement Recipes\n[C-05: Advisory/Periodic only]"
    style=filled
    fillcolor="#FFEBEE"
    color="#B71C1C"

    repo_audit [label="repo-audit\ncurl -sL fetch" shape=box3d fillcolor="#FFCDD2"]
    eco_audit [label="ecosystem-audit\n(staged, curl)" shape=box3d fillcolor="#FFCDD2"]
    docgen [label="document-generation\n(v8.1.0, 126KB)" shape=box3d fillcolor="#FFCDD2"]
  }

  // ===================================================================
  // CROSS-REPO GOVERNANCE [D-02]
  // ===================================================================
  subgraph cluster_crossrepo {
    label="Cross-Repo Governance\n[D-02: No coordination mechanism]"
    style="filled,dashed"
    fillcolor="#EFEBE9"
    color="#795548"

    ctx_poisoning [label="CONTEXT_POISONING.md\n(foundation repo)" shape=note fillcolor="#D7CCC8"]
    doc_linking [label="DOCUMENTATION_LINKING.md\n(core repo)" shape=note fillcolor="#D7CCC8"]
  }

  // ===================================================================
  // EDGES: Content pipeline (governance -> knowledge architecture)
  // ===================================================================
  repo_rules -> at_mention [label="@amplifier:docs/\nTier 1 reference" color="#9C27B0" penwidth=1.5]
  ctx_overview -> bhv_expert [label="context.include" color="#2E7D32"]
  ctx_hygiene -> bhv_dev [label="context.include" color="#2E7D32"]
  bhv_expert -> expert_agent [label="agents.include\n[C-10]" color="#2E7D32" penwidth=1.5]

  // ===================================================================
  // EDGES: 5-Tier hierarchy references
  // ===================================================================
  expert_agent -> tier0 [label="@core:docs/" color="#7B1FA2"]
  expert_agent -> tier1 [label="@amplifier:docs/" color="#7B1FA2"]
  expert_agent -> tier2 [label="@foundation:docs/" color="#7B1FA2"]
  expert_agent -> tier3 [label="@foundation:context/" color="#7B1FA2"]
  expert_agent -> tier4 [label="@recipes:docs/" color="#7B1FA2"]

  // ===================================================================
  // EDGES: Hub-and-spoke routing
  // ===================================================================
  expert_agent -> spoke_agents [label="convention-based\ndelegation [C-07]" style=dashed color="#D32F2F"]

  // ===================================================================
  // EDGES: @-mention delivery chain
  // ===================================================================
  tier0 -> at_mention [style=dashed color="#7B1FA2" dir=back]
  tier1 -> at_mention [style=dashed color="#7B1FA2" dir=back]
  at_mention -> prompt_factory [label="resolved content\n[C-03]" color="#7B1FA2" penwidth=1.5]
  prompt_factory -> expert_agent [label="assembled prompt\n(per-request)" color="#7B1FA2" penwidth=1.5]

  // ===================================================================
  // EDGES: Module loading infrastructure
  // ===================================================================
  bundle_prepare -> source_resolver [label="resolve URIs" color="#43A047"]
  bundle_prepare -> bundle_resolver [label="creates resolver" color="#43A047"]
  bundle_resolver -> coordinator [label="mount as\nmodule-source-resolver\n[D-05: PyO3 bridge?]" style=dashed color="#5C6BC0"]
  coordinator -> session_init [label="initialize()" color="#5C6BC0"]
  session_init -> module_loader [label="load modules\n[C-09: asymmetric\nerror handling]" color="#5C6BC0"]
  module_loader -> polyglot [label="transport dispatch" color="#5C6BC0"]

  // ===================================================================
  // EDGES: MODULES.md SPOF bypass — TIGHT coupling (RED)
  // ===================================================================
  repo_audit -> modules_md [label="curl -sL\n(bypasses @-mention)" style=dashed color=red penwidth=2.5]
  eco_audit -> modules_md [label="curl + extract\n(bypasses @-mention)" style=dashed color=red penwidth=2.5]

  // ===================================================================
  // EDGES: Enforcement gap
  // ===================================================================
  repo_audit -> repo_rules [label="enforces boilerplate\nonly (Golden Rule\nNOT enforced)" style=dashed color=red penwidth=1.5]

  // ===================================================================
  // EDGES: Document generation cycle (C-11)
  // ===================================================================
  docgen -> ctx_hygiene [label="generates\nupdated docs\n[C-11]" style=dashed color="#E65100"]

  // ===================================================================
  // EDGES: Silent degradation chain
  // ===================================================================
  broken_refs -> at_mention [label="silent gaps\n[C-04: no diagnostic]" style=dotted color="#C62828" penwidth=1.5]

  // ===================================================================
  // EDGES: Cross-repo governance (no cross-reference)
  // ===================================================================
  repo_rules -> ctx_poisoning [label="no cross-ref\n[D-02]" style=dashed color="#795548"]
  repo_rules -> doc_linking [label="no cross-ref\n[D-02]" style=dashed color="#795548"]

  // ===================================================================
  // DISCREPANCY EDGES (dashed red, labeled D-NN)
  // ===================================================================
  expert_agent -> tier0 [label="D-01: eager or\nlazy load?" style=dashed color=red fontcolor=red penwidth=1.5 constraint=false]
  expert_agent -> ctx_recipes [label="D-04: soft ref\nmechanism?" style=dotted color=red fontcolor=red]

  // ===================================================================
  // LEGEND
  // ===================================================================
  subgraph cluster_legend {
    label="Legend"
    style=filled
    fillcolor=white
    color=black

    node [shape=plaintext fillcolor=white]
    LEGEND [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2"><B>Edge Styles (Consensus)</B></TD></TR>
      <TR><TD>Solid green</TD><TD>Content pipeline (context injection)</TD></TR>
      <TR><TD>Solid/dashed purple</TD><TD>@-mention delivery chain</TD></TR>
      <TR><TD>Solid blue</TD><TD>Module loading infrastructure</TD></TR>
      <TR><TD>Dashed orange</TD><TD>Document generation cycle</TD></TR>
      <TR><TD BGCOLOR="#FFD0D0">Dashed red (thick)</TD><TD>TIGHT coupling / SPOF bypass</TD></TR>
      <TR><TD>Dotted dark red</TD><TD>Silent degradation path</TD></TR>
      <TR><TD>Dashed brown</TD><TD>Cross-repo governance (no link)</TD></TR>
      <TR><TD COLSPAN="2"><B>Edge Styles (Discrepancy)</B></TD></TR>
      <TR><TD BGCOLOR="#FFD0D0">Dashed red + D-NN</TD><TD>Open discrepancy (unresolved)</TD></TR>
      <TR><TD COLSPAN="2"><B>Node Shapes</B></TD></TR>
      <TR><TD BGCOLOR="#BBDEFB">note</TD><TD>Documentation / config artifact</TD></TR>
      <TR><TD BGCOLOR="#CE93D8">hexagon</TD><TD>Shared protocol / interface</TD></TR>
      <TR><TD BGCOLOR="#C8E6C9">doubleoctagon</TD><TD>Hub agent</TD></TR>
      <TR><TD BGCOLOR="#C5CAE9">box / box3d</TD><TD>Code mechanism / recipe</TD></TR>
      <TR><TD BGCOLOR="#E1BEE7">component</TD><TD>Knowledge tier (external)</TD></TR>
      <TR><TD BGCOLOR="#FFCDD2">red fill</TD><TD>SPOF / risk node</TD></TR>
    </TABLE>>]
  }
}
