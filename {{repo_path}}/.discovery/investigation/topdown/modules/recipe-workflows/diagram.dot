digraph recipe_workflow_patterns {
    graph [label="Recipe Workflow Patterns — Direct Investigation Synthesis\nSource: 16 recipe YAML files across amplifier + dot-graph-bundle", fontsize=14, rankdir=TB, compound=true, nodesep=0.6, ranksep=0.8]
    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=8]

    // === RECIPE TAXONOMY ===
    subgraph cluster_taxonomy {
        label="Recipe Taxonomy (16 recipes, 11,345 lines)"
        style=filled
        fillcolor="#E8F4FD"
        node [shape=box, fillcolor="#B8D8F8"]

        flat_recipes [label="Flat Recipes (steps only)\n4 amplifier + 7 dot-graph\n112–2,277 lines"]
        staged_recipes [label="Staged Recipes (approval gates)\n2 amplifier + 3 dot-graph\n377–3,021 lines"]
    }

    // === STRUCTURAL PATTERNS ===
    subgraph cluster_structural {
        label="Structural Patterns"
        style=filled
        fillcolor="#EDF7ED"
        node [shape=box, fillcolor="#A8D8A8"]

        orch_worker [label="Orchestrator/Worker Pairs\n• ecosystem-audit → repo-audit\n• ecosystem-activity → repo-activity\n• discovery-pipeline → strategy-*"]
        foreach_fan [label="Foreach Fan-Out\n• over repos (activity, audit)\n• over topics (discovery)\n• over chunks (repo-activity)"]
        sub_recipe [label="Sub-Recipe Composition\n• @bundle:path resolution\n• relative path ./recipe.yaml\n• context passing + output delta"]
        conditional [label="Conditional Execution\n• condition: expressions\n• string equality checks\n• boolean guards"]
    }

    // === APPROVAL GATE PATTERNS ===
    subgraph cluster_approval {
        label="Approval Gate Patterns"
        style=filled
        fillcolor="#F3ECFA"
        node [shape=box, fillcolor="#D4AAEE"]

        single_gate [label="Single Gate\n• ecosystem-audit: after discovery\n• discovery-pipeline: after scan"]
        multi_gate [label="Multi-Gate Pipeline\n• document-generation: 5 gates\n• init → gen → structural →\n  content → quality → final"]
    }

    // === DATA FLOW CONVENTIONS ===
    subgraph cluster_data {
        label="Data Flow Conventions"
        style=filled
        fillcolor="#FFF9E6"
        node [shape=box, fillcolor="#FFE88A"]

        context_bus [label="Context Dict as Data Bus\nUniversal state carrier\n[cross-ref: recipe-orchestration]"]
        file_passing [label="File-Based Data Passing\nComplex JSON via files\nnot template variables"]
        precomputed [label="_precomputed Convention\nParent pre-calculates values\nfor child recipe optimization", style="filled,dashed"]
        modules_bypass [label="MODULES.md Bypass\n3 independent fetch mechanisms\ncurl | gh api | local read", fillcolor="#FFCDD2"]
    }

    // === COST & RELIABILITY ===
    subgraph cluster_cost {
        label="Cost & Reliability Patterns"
        style=filled
        fillcolor="#FFF5E6"
        node [shape=box, fillcolor="#FFD0A0"]

        model_tiers [label="Model Tier Strategy\nhaiku: parsing, classification\nsonnet: analysis, synthesis\nopus: generation (doc-gen only)"]
        rate_limiting [label="Rate Limiting (3 tiers)\nRecipe-level: max_concurrent_llm\nOrchestrator: min_delay_ms\nBash: api_delay_seconds\n[D-01: asymmetry OPEN]", style="filled,dashed"]
        retry_config [label="Retry Configuration\nmax_attempts: 3\nexponential backoff\nper-step timeout"]
        provider_fallback [label="Provider Preference Lists\nanthropic → openai → azure\nGlob patterns: claude-haiku-*"]
    }

    // === EVOLUTION PATTERNS ===
    subgraph cluster_evolution {
        label="Evolution Patterns"
        style=filled
        fillcolor="#F0F0FF"
        node [shape=box, fillcolor="#BBBBEE"]

        changelog_driven [label="Changelog-Driven Development\nVersioned in-file changelogs\n8+ versions (doc-gen)\n15+ versions (activity-report)"]
        complexity_growth [label="Iterative Complexity Growth\nrepo-activity: 1189 lines\necosystem-activity: 1487 lines\ndocument-generation: 3021 lines"]
        workaround_accum [label="Workaround Accumulation\nprintf for bash safety\nfile-based data passing\ngc.collect() for memory", style="filled,dashed"]
    }

    // === SCALE COMPARISON ===
    subgraph cluster_scale {
        label="Scale: Amplifier vs Dot-Graph Recipes"
        style=filled
        fillcolor="#F5F5F5"
        node [shape=box, fillcolor="#CCCCCC"]

        amplifier_recipes [label="Amplifier Recipes (6)\n9,467 lines total\n590–3,021 lines each\nDomain: ecosystem ops"]
        dotgraph_recipes [label="Dot-Graph Recipes (10)\n1,878 lines total\n112–380 lines each\nDomain: codebase discovery"]
    }

    // === LEGEND ===
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#FAFAFA"
        fontsize=9
        node [shape=box, fontsize=8]

        l_high [label="Solid = Direct evidence\nfrom source examination", fillcolor="#A8D8A8"]
        l_med [label="Dashed = Inferred pattern\nor single-occurrence", fillcolor="#FFFFFF", style="filled,dashed"]
        l_tension [label="Red = Boundary tension\nor open question", fillcolor="#FFCDD2"]
        l_note [label="NOTE: No triplicate agents\nproduced artifacts.\nAll findings from direct\nsource examination.", fillcolor="#FFF3E0"]
        l_high -> l_med -> l_tension -> l_note [style=invis]
    }

    // ===== EDGES: Taxonomy to patterns =====
    flat_recipes -> foreach_fan [label="common in"]
    flat_recipes -> conditional [label="uses"]
    staged_recipes -> multi_gate [label="enables"]
    staged_recipes -> single_gate [label="enables"]

    // ===== EDGES: Structural composition =====
    orch_worker -> sub_recipe [label="implements via"]
    orch_worker -> foreach_fan [label="fans out with"]
    foreach_fan -> sub_recipe [label="type: recipe"]
    sub_recipe -> context_bus [label="passes context"]

    // ===== EDGES: Data flow =====
    context_bus -> file_passing [label="workaround for\nlarge payloads", style=dashed]
    context_bus -> precomputed [label="optimization\nconvention", style=dashed]
    sub_recipe -> precomputed [label="parent→child", style=dashed]
    context_bus -> modules_bypass [label="TENSION: bypasses\n@-mention protocol", color="#F44336", style=dashed, penwidth=1.5]

    // ===== EDGES: Cost patterns =====
    model_tiers -> amplifier_recipes [label="3 of 6\nrecipes use"]
    model_tiers -> provider_fallback [label="per-step\nconfiguration"]
    rate_limiting -> orch_worker [label="orchestrator\nowns rate config"]
    retry_config -> foreach_fan [label="per-iteration\nresilience"]

    // ===== EDGES: Evolution =====
    changelog_driven -> complexity_growth [label="documents"]
    complexity_growth -> workaround_accum [label="drives"]
    workaround_accum -> file_passing [label="template→bash\nfragility", color="#F44336", style=dashed]

    // ===== EDGES: Scale =====
    amplifier_recipes -> orch_worker [label="2 pairs"]
    dotgraph_recipes -> sub_recipe [label="deep nesting\npipeline→strategy→\ntopic→module"]

    // ===== EDGES: Approval patterns =====
    single_gate -> orch_worker [label="gate before\nfan-out"]
    multi_gate -> complexity_growth [label="doc-gen: 5 gates\nacross 3021 lines"]
}
